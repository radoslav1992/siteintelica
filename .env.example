# SiteIntelica Environment Variables

# Google Gemini API key for AI-powered features (summaries, cold emails, SEO audits)
# Optional: AI features fall back to local generation when not set
GEMINI_API_KEY=your_gemini_key_here

# Google API key for CrUX (Chrome UX Report) real-user metrics
# Get one at https://console.cloud.google.com/apis/credentials
# Enable "Chrome UX Report API" in your GCP project
# Also used by PageSpeed Insights if GOOGLE_API_KEY is set
CRUX_API_KEY=your_google_api_key_here

# Open PageRank API key for backlink authority scoring (0-10 scale)
# Free tier: 100 requests/day — sign up at https://www.domcop.com/openpagerank/
OPEN_PAGERANK_KEY=your_openpagerank_key_here

# SQLite database path (defaults to ./siteintelica_scans.db)
# DB_PATH=./siteintelica_scans.db

# Rust engine URL for premium port scanning (defaults to http://127.0.0.1:8080)
# ENGINE_URL=http://127.0.0.1:8080
