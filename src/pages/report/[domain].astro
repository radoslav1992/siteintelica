---
import Layout from '../../layouts/Layout.astro';
import { getPublicReport } from '../../db/client';
import { calculateSecurityGrade } from '../../utils/security-grade';

const GRADE_COLORS: Record<string, string> = {
  'A': 'var(--success)',
  'B': 'var(--success)',
  'C': 'var(--warning)',
  'D': 'var(--warning)',
  'F': 'var(--danger)'
};

const { domain } = Astro.params;

if (!domain) {
  return Astro.redirect('/404');
}

const report = getPublicReport(domain);

if (!report) {
  return Astro.redirect('/404');
}

const data = report.data;
const scannedAt = new Date(report.scannedAt + ' Z').toLocaleString();
const securityGrade = calculateSecurityGrade(data?.security);
const gradeColor = GRADE_COLORS[securityGrade.grade] || 'var(--danger)';
---

<Layout title={`${domain} Tech Stack Report`}>
  <div class="container page-content">
    <header class="page-header">
      <div class="domain-header">
        <img src={`https://logo.clearbit.com/${domain}`} alt="" width="48" height="48" class="domain-logo" loading="lazy" onerror="this.style.display='none'" />
        <h1 class="text-gradient text-4xl font-extrabold">{domain}</h1>
      </div>
      <p class="text-secondary text-sm">Last scanned: {scannedAt}</p>
      <div class="rescan-row">
        <a href={`/?scan=https://${domain}`} class="btn-primary" style="padding:0.5rem 1.5rem; font-size:0.85rem;">Re-Scan Now</a>
      </div>
    </header>

    <div class="report-grid">
      <div class="glass-panel p-6 animate-fade-in">
        <h3 class="card-title">Security Grade</h3>
        <div class="grade-row">
          <div class="grade-badge" style={`background: hsl(${gradeColor} / 0.12); border-color: hsl(${gradeColor}); color: hsl(${gradeColor});`}>
            {securityGrade.grade}
          </div>
          <div style="flex:1;">
            <div class="text-sm text-secondary mb-1">Score: {securityGrade.score}/100</div>
            <div class="score-bar-track">
              <div class="score-bar-fill" style={`width:${securityGrade.score}%; background:hsl(${gradeColor});`}></div>
            </div>
          </div>
        </div>
      </div>

      {data.seo && (
        <div class="glass-panel p-6 animate-fade-in" style="animation-delay:0.05s;">
          <h3 class="card-title">SEO</h3>
          <div class="font-semibold text-sm mb-1">{data.seo.title || 'No title tag'}</div>
          <div class="text-xs text-secondary" style="line-height:1.5;">{data.seo.description ? data.seo.description.substring(0, 120) + '...' : 'No meta description found.'}</div>
        </div>
      )}

      {data.performance && (
        <div class="glass-panel p-6 animate-fade-in" style="animation-delay:0.1s;">
          <h3 class="card-title">Performance</h3>
          <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
            {data.performance.score != null && <div class="badge">Perf: {data.performance.score}</div>}
            {data.performance.seo != null && <div class="badge">SEO: {data.performance.seo}</div>}
            {data.performance.accessibility != null && <div class="badge">A11y: {data.performance.accessibility}</div>}
          </div>
        </div>
      )}

      {data.technologies && data.technologies.length > 0 && (
        <div class="glass-panel p-6 animate-fade-in tech-card" style="animation-delay:0.15s;">
          <h3 class="card-title">Detected Technologies ({data.technologies.length})</h3>
          <div class="tech-list" style="gap:0.35rem;">
            {data.technologies.map((tech: any) => (
              <div class="badge" style="display:flex; align-items:center; gap:6px;">
                <img src={`https://logo.clearbit.com/${tech.website?.replace('https://', '').replace('http://', '').split('/')[0]}`} width="14" height="14" style="border-radius:3px;" onerror="this.style.display='none'" alt="" loading="lazy" />
                {tech.name}
                {tech.version && <span class="text-xs text-muted">v{tech.version}</span>}
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>

  <style>
    .page-content {
      padding-top: 6rem;
      padding-bottom: 6rem;
    }

    .page-header {
      text-align: center;
      margin-bottom: 2.5rem;
    }

    .domain-header {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      margin-bottom: 0.5rem;
    }

    .domain-logo {
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.06);
    }

    .rescan-row {
      display: flex;
      gap: 0.5rem;
      justify-content: center;
      margin-top: 0.75rem;
    }

    .report-grid {
      max-width: 900px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1rem;
    }

    .card-title {
      font-size: 1rem;
      font-weight: 700;
      margin-bottom: 0.75rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .grade-row {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .grade-badge {
      width: 56px;
      height: 56px;
      border-radius: 12px;
      border: 2px solid;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
      font-weight: 800;
      flex-shrink: 0;
    }

    .score-bar-track {
      width: 100%;
      height: 6px;
      background: rgba(255, 255, 255, 0.06);
      border-radius: 3px;
      overflow: hidden;
    }

    .score-bar-fill {
      height: 100%;
      border-radius: 3px;
    }

    .tech-card {
      grid-column: 1 / -1;
    }

    .tech-list {
      display: flex;
      flex-wrap: wrap;
    }
  </style>
</Layout>
