---
import Layout from '../layouts/Layout.astro';
export const prerender = false;
---

<Layout title="Bulk Scanner">
  <div class="container page-content">
    <header class="page-header">
      <h1 class="text-gradient">Bulk Scanner</h1>
      <p class="text-secondary">Scan multiple websites at once. Paste one URL per line.</p>
    </header>

    <div class="content-wrapper">
      <div class="glass-panel textarea-card">
        <textarea id="bulk-urls" rows="8" placeholder="https://stripe.com&#10;https://github.com&#10;https://shopify.com" class="bulk-textarea"></textarea>

        <div class="textarea-footer">
          <span id="url-count" class="url-counter">0 URLs</span>
          <div class="actions">
            <button id="export-csv" class="btn-secondary export-btn" style="display:none;">Export CSV</button>
            <button id="start-bulk" class="btn-primary scan-btn">Start Scanning</button>
          </div>
        </div>
      </div>

      <div id="progress-area" class="glass-panel progress-card" style="display:none;">
        <div class="progress-header">
          <span class="font-semibold">Scanning...</span>
          <span id="progress-text" class="text-sm text-secondary">0/0</span>
        </div>
        <div class="progress-track">
          <div id="progress-bar" class="progress-fill"></div>
        </div>
      </div>

      <div id="bulk-results" class="results-area"></div>
    </div>
  </div>

  <style>
    .page-content {
      padding-top: 6rem;
      padding-bottom: 6rem;
    }

    .page-header {
      text-align: center;
      margin-bottom: 2rem;
    }

    .page-header h1 {
      font-size: 2.25rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      margin-bottom: 0.5rem;
    }

    .content-wrapper {
      max-width: 900px;
      margin: 0 auto;
    }

    .textarea-card {
      padding: 1.5rem;
    }

    .bulk-textarea {
      width: 100%;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: var(--radius-sm);
      padding: 0.85rem;
      color: hsl(var(--text-primary));
      font-family: var(--font-mono);
      font-size: 0.85rem;
      resize: vertical;
      outline: none;
      transition: border-color var(--transition-smooth);
    }

    .bulk-textarea:focus {
      border-color: hsl(var(--accent-primary));
    }

    .bulk-textarea::placeholder {
      color: hsl(var(--text-muted));
    }

    .textarea-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 1rem;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .url-counter {
      font-size: 0.8rem;
      color: hsl(var(--text-secondary));
    }

    .actions {
      display: flex;
      gap: 0.75rem;
    }

    .scan-btn {
      padding: 0.6rem 1.5rem;
    }

    .export-btn {
      padding: 0.5rem 1rem;
      background: hsla(var(--success), 0.12);
      color: hsl(var(--success));
      border-color: hsla(var(--success), 0.25);
    }

    .progress-card {
      margin-top: 1.5rem;
      padding: 1rem 1.25rem;
    }

    .progress-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.5rem;
    }

    .progress-track {
      height: 6px;
      background: rgba(255, 255, 255, 0.06);
      border-radius: 3px;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      width: 0%;
      background: hsl(var(--accent-primary));
      border-radius: 3px;
      transition: width 0.3s;
    }

    .results-area {
      margin-top: 1.5rem;
    }
  </style>

  <script>
    const textarea = document.getElementById('bulk-urls') as HTMLTextAreaElement;
    const urlCount = document.getElementById('url-count')!;
    const startBtn = document.getElementById('start-bulk') as HTMLButtonElement;
    const exportBtn = document.getElementById('export-csv') as HTMLButtonElement;
    const progressArea = document.getElementById('progress-area')!;
    const progressBar = document.getElementById('progress-bar')!;
    const progressText = document.getElementById('progress-text')!;
    const resultsArea = document.getElementById('bulk-results')!;

    let scanResults: any[] = [];

    function getUrls(): string[] {
      return textarea.value.split('\n')
        .map(l => l.trim())
        .filter(l => l.length > 0)
        .map(l => l.startsWith('http') ? l : `https://${l}`);
    }

    textarea.addEventListener('input', () => {
      const count = getUrls().length;
      urlCount.textContent = `${count} URL${count !== 1 ? 's' : ''}`;
    });

    startBtn.addEventListener('click', async () => {
      const urls = getUrls();
      if (urls.length === 0) return;

      startBtn.disabled = true;
      startBtn.style.opacity = '0.5';
      progressArea.style.display = 'block';
      resultsArea.innerHTML = '';
      scanResults = [];
      exportBtn.style.display = 'none';

      for (let i = 0; i < urls.length; i++) {
        progressText.textContent = `${i + 1}/${urls.length}`;
        progressBar.style.width = `${((i + 1) / urls.length) * 100}%`;

        const url = urls[i];
        const card = document.createElement('div');
        card.className = 'glass-panel';
        card.style.cssText = 'padding:0.85rem 1.25rem; margin-bottom:0.5rem; display:flex; justify-content:space-between; align-items:center; border-left:3px solid transparent;';

        try {
          const domain = new URL(url).hostname;
          card.innerHTML = `<div><strong>${domain}</strong> <span style="font-size:0.75rem; color:hsl(var(--text-secondary));">scanning...</span></div>`;
          resultsArea.appendChild(card);

          const response = await fetch('/api/analyze', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ url })
          });

          if (!response.ok) throw new Error(`HTTP ${response.status}`);
          const data = await response.json();

          const techCount = data.technologies?.length || 0;
          const perf = data.performance?.score ?? '—';
          const seo = data.performance?.seo ?? '—';
          const grade = data.securityGrade?.grade || '—';

          card.style.borderLeftColor = 'hsl(var(--success))';
          card.innerHTML = `
            <div>
              <a href="/?scan=${url}" style="font-weight:700; color:inherit; text-decoration:none;">${domain}</a>
              <div style="font-size:0.75rem; color:hsl(var(--text-secondary)); margin-top:2px;">${techCount} technologies</div>
            </div>
            <div style="display:flex; gap:0.5rem; align-items:center;">
              <span class="badge" style="font-size:0.7rem;">Perf: ${perf}</span>
              <span class="badge" style="font-size:0.7rem;">SEO: ${seo}</span>
              <span class="badge" style="font-size:0.7rem;">Sec: ${grade}</span>
            </div>
          `;

          scanResults.push({ domain, techCount, perf, seo, securityGrade: grade, status: 'OK' });
        } catch {
          card.style.borderLeftColor = 'hsl(var(--danger))';
          const domain = (() => { try { return new URL(url).hostname; } catch { return url; } })();
          card.innerHTML = `<div><strong>${domain}</strong></div><span class="badge" style="color:hsl(var(--danger)); font-size:0.7rem;">Failed</span>`;
          scanResults.push({ domain, techCount: 0, perf: 0, seo: 0, securityGrade: '—', status: 'FAILED' });
        }
      }

      progressText.textContent = `Done! ${urls.length}/${urls.length}`;
      startBtn.disabled = false;
      startBtn.style.opacity = '1';
      exportBtn.style.display = 'inline-flex';
    });

    exportBtn.addEventListener('click', () => {
      if (scanResults.length === 0) return;
      const headers = ['Domain', 'Technologies', 'Performance', 'SEO', 'Security Grade', 'Status'];
      const rows = scanResults.map(r => [r.domain, r.techCount, r.perf, r.seo, r.securityGrade, r.status]);
      const csv = [headers.join(','), ...rows.map(r => r.join(','))].join('\n');
      const blob = new Blob([csv], { type: 'text/csv' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `siteintelica-bulk-${new Date().toISOString().slice(0, 10)}.csv`;
      a.click();
      URL.revokeObjectURL(url);
    });
  </script>
</Layout>
