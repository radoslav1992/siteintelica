---
import Layout from '../layouts/Layout.astro';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/login");
}
---

<Layout title="Compare Sites | SiteIntelica">
  <div class="container pt-32 pb-24">
    <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 3rem; text-align: center;">
      <h1 class="text-4xl font-extrabold text-gradient">Side-by-Side Comparison</h1>
      <p class="text-secondary text-lg">Compare the tech stacks, security postures, and performance of two competing websites.</p>
    </div>

    <div style="max-width: 800px; margin: 0 auto;">
      <form id="compareForm" class="glass-panel p-6 animate-fade-in" style="display:flex; flex-direction:column; gap:1rem;">
        <div style="display:grid; grid-template-columns:1fr auto 1fr; gap:1rem; align-items:center;">
          <input type="url" id="urlA" placeholder="https://stripe.com" class="search-input" style="padding:0.75rem 1rem; background:rgba(0,0,0,0.2) !important; color:#fff;" required />
          <span style="font-weight:800; color:hsl(var(--accent-primary)); font-size:1.2rem;">VS</span>
          <input type="url" id="urlB" placeholder="https://paddle.com" class="search-input" style="padding:0.75rem 1rem; background:rgba(0,0,0,0.2) !important; color:#fff;" required />
        </div>
        <button type="submit" class="btn-primary" id="compareBtn" style="position:static; width:100%; padding:0.75rem;">Compare Now</button>
      </form>

      <div id="compareResults" class="hidden" style="margin-top:2rem;"></div>
      <p id="compareStatus" class="text-sm mt-4 text-secondary hidden" style="text-align:center;"></p>
    </div>
  </div>

  <script>
    const form = document.getElementById('compareForm') as HTMLFormElement;
    const btn = document.getElementById('compareBtn') as HTMLButtonElement;
    const results = document.getElementById('compareResults')!;
    const status = document.getElementById('compareStatus')!;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const urlA = (document.getElementById('urlA') as HTMLInputElement).value;
      const urlB = (document.getElementById('urlB') as HTMLInputElement).value;

      btn.disabled = true;
      btn.innerText = 'Scanning both sites...';
      status.innerText = 'Running parallel deep scans. This may take up to 30 seconds...';
      status.classList.remove('hidden');
      status.style.color = 'hsl(var(--text-secondary))';
      results.classList.add('hidden');

      try {
        const [resA, resB] = await Promise.all([
          fetch('/api/analyze', { method: 'POST', body: JSON.stringify({ url: urlA }), headers: { 'Content-Type': 'application/json' } }),
          fetch('/api/analyze', { method: 'POST', body: JSON.stringify({ url: urlB }), headers: { 'Content-Type': 'application/json' } })
        ]);

        if (!resA.ok || !resB.ok) throw new Error('One or both scans failed.');

        const dataA = await resA.json();
        const dataB = await resB.json();

        const domainA = new URL(urlA).hostname;
        const domainB = new URL(urlB).hostname;

        const techsA = new Set((dataA.technologies || []).map((t: any) => t.name));
        const techsB = new Set((dataB.technologies || []).map((t: any) => t.name));

        const shared = [...techsA].filter(t => techsB.has(t));
        const onlyA = [...techsA].filter(t => !techsB.has(t));
        const onlyB = [...techsB].filter(t => !techsA.has(t));

        const gradeA = dataA.securityGrade || { grade: '?', score: 0 };
        const gradeB = dataB.securityGrade || { grade: '?', score: 0 };
        const perfA = dataA.performance || {};
        const perfB = dataB.performance || {};

        const gradeColors: Record<string, string> = { 'A': '#00e676', 'B': '#66bb6a', 'C': '#ffa726', 'D': '#ff7043', 'F': '#ff4b4b' };

        results.innerHTML = `
          <!-- Head-to-Head -->
          <div class="glass-panel p-6 animate-fade-in" style="margin-bottom:1rem;">
            <h3 class="category-title">Head-to-Head</h3>
            <div style="display:grid; grid-template-columns:1fr auto 1fr; gap:1rem; text-align:center;">
              <div>
                <img src="https://logo.clearbit.com/${domainA}" width="32" height="32" style="border-radius:6px; background:rgba(255,255,255,0.1); margin-bottom:0.5rem;" onerror="this.style.display='none'" />
                <div style="font-weight:700;">${domainA}</div>
                <div style="font-size:0.8rem; color:hsl(var(--text-secondary));">${techsA.size} technologies</div>
              </div>
              <div style="display:flex; align-items:center; font-weight:800; color:hsl(var(--accent-primary)); font-size:1.5rem;">VS</div>
              <div>
                <img src="https://logo.clearbit.com/${domainB}" width="32" height="32" style="border-radius:6px; background:rgba(255,255,255,0.1); margin-bottom:0.5rem;" onerror="this.style.display='none'" />
                <div style="font-weight:700;">${domainB}</div>
                <div style="font-size:0.8rem; color:hsl(var(--text-secondary));">${techsB.size} technologies</div>
              </div>
            </div>
          </div>

          <!-- Security & Performance -->
          <div class="glass-panel p-6 animate-fade-in" style="margin-bottom:1rem; animation-delay:0.05s;">
            <h3 class="category-title">Security & Performance</h3>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
              <div style="text-align:center;">
                <div style="font-size:2rem; font-weight:800; color:${gradeColors[gradeA.grade] || '#888'};">${gradeA.grade}</div>
                <div style="font-size:0.75rem; color:hsl(var(--text-secondary));">${domainA} (${gradeA.score}/100)</div>
                ${perfA.performanceScore != null ? `<div class="badge" style="margin-top:4px;">Perf: ${perfA.performanceScore}</div>` : ''}
              </div>
              <div style="text-align:center;">
                <div style="font-size:2rem; font-weight:800; color:${gradeColors[gradeB.grade] || '#888'};">${gradeB.grade}</div>
                <div style="font-size:0.75rem; color:hsl(var(--text-secondary));">${domainB} (${gradeB.score}/100)</div>
                ${perfB.performanceScore != null ? `<div class="badge" style="margin-top:4px;">Perf: ${perfB.performanceScore}</div>` : ''}
              </div>
            </div>
          </div>

          <!-- Shared Technologies -->
          <div class="glass-panel p-6 animate-fade-in" style="margin-bottom:1rem; animation-delay:0.1s;">
            <h3 class="category-title">Shared Technologies (${shared.length})</h3>
            <div class="tech-list" style="gap:0.4rem;">
              ${shared.map(t => `<div class="badge">${t}</div>`).join('')}
              ${shared.length === 0 ? '<span style="color:hsl(var(--text-secondary)); font-size:0.85rem;">No shared technologies detected.</span>' : ''}
            </div>
          </div>

          <!-- Unique to A -->
          <div class="glass-panel p-6 animate-fade-in" style="margin-bottom:1rem; animation-delay:0.15s; border-left:3px solid hsl(var(--accent-primary));">
            <h3 class="category-title">Only on ${domainA} (${onlyA.length})</h3>
            <div class="tech-list" style="gap:0.4rem;">
              ${onlyA.map(t => `<div class="badge" style="background:hsla(var(--accent-primary), 0.15); color:hsl(var(--accent-primary));">${t}</div>`).join('')}
              ${onlyA.length === 0 ? '<span style="color:hsl(var(--text-secondary)); font-size:0.85rem;">None.</span>' : ''}
            </div>
          </div>

          <!-- Unique to B -->
          <div class="glass-panel p-6 animate-fade-in" style="margin-bottom:1rem; animation-delay:0.2s; border-left:3px solid hsl(var(--accent-secondary));">
            <h3 class="category-title">Only on ${domainB} (${onlyB.length})</h3>
            <div class="tech-list" style="gap:0.4rem;">
              ${onlyB.map(t => `<div class="badge" style="background:hsla(var(--accent-secondary), 0.15); color:hsl(var(--accent-secondary));">${t}</div>`).join('')}
              ${onlyB.length === 0 ? '<span style="color:hsl(var(--text-secondary)); font-size:0.85rem;">None.</span>' : ''}
            </div>
          </div>

          <!-- AI Competitor Gap Analysis -->
          <div class="glass-panel p-6 animate-fade-in" style="margin-bottom:1rem; animation-delay:0.25s; border-top:3px solid #FFD700;">
            <h3 class="category-title">🤖 AI Competitor Gap Analysis <span class="badge" style="font-size:0.6rem; margin-left:8px; background:rgba(255,215,0,0.15); color:#FFD700; border:1px solid rgba(255,215,0,0.3);">★ PREMIUM</span></h3>
            <button id="btnGap" style="width:100%; padding:0.75rem; border-radius:8px; border:1px solid hsla(var(--accent-primary), 0.3); background:rgba(0,0,0,0.2); color:hsl(var(--text-primary)); cursor:pointer; font-size:0.85rem; font-weight:600; transition:all 0.2s;" onmouseover="this.style.borderColor='hsl(var(--accent-primary))'" onmouseout="this.style.borderColor='hsla(var(--accent-primary), 0.3)'">
              🔍 Generate AI Gap Report for ${domainA} vs ${domainB}
            </button>
            <div id="gapOutput" style="margin-top:1rem; display:none; padding:1rem; background:rgba(0,0,0,0.3); border-radius:8px; font-size:0.82rem; line-height:1.6; white-space:pre-wrap; max-height:400px; overflow-y:auto;"></div>
          </div>
        `;

        results.classList.remove('hidden');
        status.innerText = 'Comparison complete!';
        status.style.color = '#00e676';

        // Wire up AI Gap button
        const gapBtn = document.getElementById('btnGap');
        const gapOutput = document.getElementById('gapOutput');
        if (gapBtn && gapOutput) {
          gapBtn.addEventListener('click', async () => {
            gapBtn.disabled = true;
            gapBtn.style.opacity = '0.5';
            gapOutput.style.display = 'block';
            gapOutput.textContent = 'Running AI competitive gap analysis...';
            try {
              const res = await fetch('/api/ai/competitor-gap', {
                method: 'POST',
                body: JSON.stringify({ domainA, domainB }),
                headers: { 'Content-Type': 'application/json' }
              });
              const result = await res.json();
              if (result.analysis) {
                gapOutput.innerHTML = result.analysis
                  .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                  .replace(/##\s?(.*?)\n/g, '<h4 style="margin:0.75rem 0 0.25rem; color:hsl(var(--accent-primary));">$1</h4>')
                  .replace(/\n/g, '<br/>');
              } else {
                gapOutput.textContent = 'Error: ' + (result.error || 'Unknown error');
              }
            } catch {
              gapOutput.textContent = 'Network error generating gap analysis.';
            }
            gapBtn.disabled = false;
            gapBtn.style.opacity = '1';
          });
        }

      } catch (err: any) {
        status.innerText = 'Error: ' + (err.message || 'Failed to compare.');
        status.style.color = '#ff4b4b';
      }

      btn.disabled = false;
      btn.innerText = 'Compare Now';
    });
  </script>
</Layout>
