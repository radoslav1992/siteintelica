---
import Layout from '../layouts/Layout.astro';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/login");
}
---

<Layout title="Compare Sites">
  <div class="container page-content">
    <header class="page-header">
      <h1 class="text-gradient">Side-by-Side Comparison</h1>
      <p class="text-secondary">Compare the tech stacks, security postures, and performance of two competing websites.</p>
    </header>

    <div class="content-wrapper">
      <form id="compareForm" class="glass-panel compare-form animate-fade-in">
        <div class="compare-inputs">
          <input type="url" id="urlA" placeholder="https://stripe.com" class="compare-input" required />
          <span class="vs-label">VS</span>
          <input type="url" id="urlB" placeholder="https://paddle.com" class="compare-input" required />
        </div>
        <button type="submit" class="btn-primary compare-btn" id="compareBtn">Compare Now</button>
      </form>

      <div id="compareResults" class="hidden" style="margin-top:1.5rem;"></div>
      <p id="compareStatus" class="text-sm mt-4 text-secondary hidden text-center"></p>
    </div>
  </div>

  <style>
    .page-content {
      padding-top: 6rem;
      padding-bottom: 6rem;
    }

    .page-header {
      text-align: center;
      margin-bottom: 2.5rem;
    }

    .page-header h1 {
      font-size: 2.25rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      margin-bottom: 0.5rem;
    }

    .content-wrapper {
      max-width: 800px;
      margin: 0 auto;
    }

    .compare-form {
      padding: 1.75rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .compare-inputs {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 1rem;
      align-items: center;
    }

    .compare-input {
      width: 100%;
      padding: 0.75rem 1rem;
      background: rgba(0, 0, 0, 0.25);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: var(--radius-sm);
      color: hsl(var(--text-primary));
      font-family: var(--font-sans);
      font-size: 0.95rem;
      outline: none;
      transition: border-color var(--transition-smooth), box-shadow var(--transition-smooth);
    }

    .compare-input:focus {
      border-color: hsl(var(--accent-primary));
      box-shadow: 0 0 0 3px hsla(var(--accent-primary), 0.12);
    }

    .compare-input::placeholder {
      color: hsl(var(--text-muted));
    }

    .vs-label {
      font-weight: 800;
      color: hsl(var(--accent-primary));
      font-size: 1.1rem;
    }

    .compare-btn {
      width: 100%;
      padding: 0.85rem;
    }

    @media (max-width: 640px) {
      .compare-inputs {
        grid-template-columns: 1fr;
      }
      .vs-label { text-align: center; }
    }
  </style>

  <script>
    import { marked } from 'marked';
    marked.setOptions({ breaks: true, gfm: true });

    const form = document.getElementById('compareForm') as HTMLFormElement;
    const btn = document.getElementById('compareBtn') as HTMLButtonElement;
    const results = document.getElementById('compareResults')!;
    const status = document.getElementById('compareStatus')!;

    function buildScoreComparison(perfA: any, perfB: any, gradeA: any, gradeB: any) {
      const metrics = [
        { label: 'Performance', a: perfA.score, b: perfB.score },
        { label: 'SEO', a: perfA.seo, b: perfB.seo },
        { label: 'Accessibility', a: perfA.accessibility, b: perfB.accessibility },
        { label: 'Security', a: gradeA.score, b: gradeB.score },
      ].filter(m => m.a != null || m.b != null);

      const rows = metrics.map(m => {
        const valA = m.a ?? 0;
        const valB = m.b ?? 0;
        const winA = valA > valB;
        const winB = valB > valA;
        return '<div>' +
          '<div style="display:flex; justify-content:space-between; font-size:0.78rem; margin-bottom:3px;">' +
            '<span style="font-weight:' + (winA ? '700' : '400') + '; color:' + (winA ? '#00e676' : 'inherit') + ';">' + valA + '</span>' +
            '<span style="color:hsl(var(--text-secondary));">' + m.label + '</span>' +
            '<span style="font-weight:' + (winB ? '700' : '400') + '; color:' + (winB ? '#00e676' : 'inherit') + ';">' + valB + '</span>' +
          '</div>' +
          '<div style="display:flex; gap:2px; height:6px;">' +
            '<div style="flex:1; background:rgba(255,255,255,0.06); border-radius:3px 0 0 3px; overflow:hidden; direction:rtl;">' +
              '<div style="height:100%; width:' + valA + '%; background:' + (winA ? 'hsl(var(--accent-primary))' : 'rgba(255,255,255,0.15)') + '; border-radius:3px 0 0 3px;"></div>' +
            '</div>' +
            '<div style="flex:1; background:rgba(255,255,255,0.06); border-radius:0 3px 3px 0; overflow:hidden;">' +
              '<div style="height:100%; width:' + valB + '%; background:' + (winB ? 'hsl(var(--accent-secondary))' : 'rgba(255,255,255,0.15)') + '; border-radius:0 3px 3px 0;"></div>' +
            '</div>' +
          '</div>' +
        '</div>';
      }).join('');

      return '<div class="glass-panel" style="padding:1.5rem; margin-bottom:0.75rem;">' +
        '<h3 style="font-weight:700; font-size:1rem; margin-bottom:1rem; padding-bottom:0.75rem; border-bottom:1px solid rgba(255,255,255,0.06);">Score Comparison</h3>' +
        '<div style="display:flex; flex-direction:column; gap:0.6rem;">' + rows + '</div>' +
      '</div>';
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const urlA = (document.getElementById('urlA') as HTMLInputElement).value;
      const urlB = (document.getElementById('urlB') as HTMLInputElement).value;

      btn.disabled = true;
      btn.innerText = 'Scanning both sites...';
      status.innerText = 'Running parallel deep scans. This may take up to 30 seconds...';
      status.classList.remove('hidden');
      status.style.color = 'hsl(var(--text-secondary))';
      results.classList.add('hidden');

      try {
        const [resA, resB] = await Promise.all([
          fetch('/api/analyze', { method: 'POST', body: JSON.stringify({ url: urlA }), headers: { 'Content-Type': 'application/json' } }),
          fetch('/api/analyze', { method: 'POST', body: JSON.stringify({ url: urlB }), headers: { 'Content-Type': 'application/json' } })
        ]);

        if (!resA.ok || !resB.ok) throw new Error('One or both scans failed.');

        const dataA = await resA.json();
        const dataB = await resB.json();

        const domainA = new URL(urlA).hostname;
        const domainB = new URL(urlB).hostname;

        const techsA = new Set((dataA.technologies || []).map((t: any) => t.name));
        const techsB = new Set((dataB.technologies || []).map((t: any) => t.name));

        const shared = [...techsA].filter(t => techsB.has(t));
        const onlyA = [...techsA].filter(t => !techsB.has(t));
        const onlyB = [...techsB].filter(t => !techsA.has(t));

        const gradeA = dataA.securityGrade || { grade: '?', score: 0 };
        const gradeB = dataB.securityGrade || { grade: '?', score: 0 };
        const perfA = dataA.performance || {};
        const perfB = dataB.performance || {};

        const gradeColors: Record<string, string> = { 'A': 'var(--success)', 'B': 'var(--success)', 'C': 'var(--warning)', 'D': 'var(--warning)', 'F': 'var(--danger)' };

        results.innerHTML = `
          <div class="glass-panel" style="padding:1.5rem; margin-bottom:0.75rem;">
            <h3 style="font-weight:700; font-size:1rem; margin-bottom:1rem; padding-bottom:0.75rem; border-bottom:1px solid rgba(255,255,255,0.06);">Head-to-Head</h3>
            <div style="display:grid; grid-template-columns:1fr auto 1fr; gap:1rem; text-align:center;">
              <div>
                <img src="https://logo.clearbit.com/${domainA}" width="32" height="32" style="border-radius:8px; background:rgba(255,255,255,0.06); margin-bottom:0.5rem;" onerror="this.style.display='none'" />
                <div style="font-weight:700;">${domainA}</div>
                <div style="font-size:0.8rem; color:hsl(var(--text-secondary));">${techsA.size} technologies</div>
              </div>
              <div style="display:flex; align-items:center; font-weight:800; color:hsl(var(--accent-primary)); font-size:1.3rem;">VS</div>
              <div>
                <img src="https://logo.clearbit.com/${domainB}" width="32" height="32" style="border-radius:8px; background:rgba(255,255,255,0.06); margin-bottom:0.5rem;" onerror="this.style.display='none'" />
                <div style="font-weight:700;">${domainB}</div>
                <div style="font-size:0.8rem; color:hsl(var(--text-secondary));">${techsB.size} technologies</div>
              </div>
            </div>
          </div>

          <div class="glass-panel" style="padding:1.5rem; margin-bottom:0.75rem;">
            <h3 style="font-weight:700; font-size:1rem; margin-bottom:1rem; padding-bottom:0.75rem; border-bottom:1px solid rgba(255,255,255,0.06);">Security & Performance</h3>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
              <div style="text-align:center;">
                <div style="font-size:2rem; font-weight:800; color:hsl(${gradeColors[gradeA.grade] || 'var(--text-muted)'});">${gradeA.grade}</div>
                <div style="font-size:0.75rem; color:hsl(var(--text-secondary));">${domainA} (${gradeA.score}/100)</div>
                ${perfA.score != null ? `<div class="badge" style="margin-top:4px;">Perf: ${perfA.score}</div>` : ''}
              </div>
              <div style="text-align:center;">
                <div style="font-size:2rem; font-weight:800; color:hsl(${gradeColors[gradeB.grade] || 'var(--text-muted)'});">${gradeB.grade}</div>
                <div style="font-size:0.75rem; color:hsl(var(--text-secondary));">${domainB} (${gradeB.score}/100)</div>
                ${perfB.score != null ? `<div class="badge" style="margin-top:4px;">Perf: ${perfB.score}</div>` : ''}
              </div>
            </div>
          </div>

          <div class="glass-panel" style="padding:1.5rem; margin-bottom:0.75rem;">
            <h3 style="font-weight:700; font-size:1rem; margin-bottom:0.75rem; padding-bottom:0.75rem; border-bottom:1px solid rgba(255,255,255,0.06);">Shared Technologies (${shared.length})</h3>
            <div style="display:flex; flex-wrap:wrap; gap:0.35rem;">
              ${shared.map(t => `<div class="badge">${t}</div>`).join('')}
              ${shared.length === 0 ? '<span style="color:hsl(var(--text-secondary)); font-size:0.85rem;">No shared technologies detected.</span>' : ''}
            </div>
          </div>

          <div class="glass-panel" style="padding:1.5rem; margin-bottom:0.75rem; border-left:3px solid hsl(var(--accent-primary));">
            <h3 style="font-weight:700; font-size:1rem; margin-bottom:0.75rem; padding-bottom:0.75rem; border-bottom:1px solid rgba(255,255,255,0.06);">Only on ${domainA} (${onlyA.length})</h3>
            <div style="display:flex; flex-wrap:wrap; gap:0.35rem;">
              ${onlyA.map(t => `<div class="badge" style="background:hsla(var(--accent-primary), 0.1); color:hsl(var(--accent-primary));">${t}</div>`).join('')}
              ${onlyA.length === 0 ? '<span style="color:hsl(var(--text-secondary)); font-size:0.85rem;">None.</span>' : ''}
            </div>
          </div>

          <div class="glass-panel" style="padding:1.5rem; margin-bottom:0.75rem; border-left:3px solid hsl(var(--accent-secondary));">
            <h3 style="font-weight:700; font-size:1rem; margin-bottom:0.75rem; padding-bottom:0.75rem; border-bottom:1px solid rgba(255,255,255,0.06);">Only on ${domainB} (${onlyB.length})</h3>
            <div style="display:flex; flex-wrap:wrap; gap:0.35rem;">
              ${onlyB.map(t => `<div class="badge" style="background:hsla(var(--accent-secondary), 0.1); color:hsl(var(--accent-secondary));">${t}</div>`).join('')}
              ${onlyB.length === 0 ? '<span style="color:hsl(var(--text-secondary)); font-size:0.85rem;">None.</span>' : ''}
            </div>
          </div>

          ${buildScoreComparison(perfA, perfB, gradeA, gradeB)}

          <div class="glass-panel" style="padding:1.5rem; border-top:3px solid hsl(var(--accent-warm));">
            <h3 style="font-weight:700; font-size:1rem; margin-bottom:0.75rem; padding-bottom:0.75rem; border-bottom:1px solid rgba(255,255,255,0.06);">AI Competitor Gap Analysis <span class="badge" style="font-size:0.6rem; margin-left:6px; background:hsla(var(--accent-warm), 0.12); color:hsl(var(--accent-warm));">PREMIUM</span></h3>
            <button id="btnGap" class="btn-secondary" style="width:100%; padding:0.75rem;">Generate AI Gap Report for ${domainA} vs ${domainB}</button>
            <div id="gapOutput" class="ai-markdown-output" style="margin-top:1rem; display:none; padding:1rem; background:rgba(0,0,0,0.3); border-radius:var(--radius-sm); font-size:0.82rem; line-height:1.6; max-height:400px; overflow-y:auto;"></div>
          </div>
        `;

        results.classList.remove('hidden');
        status.innerText = 'Comparison complete!';
        status.style.color = 'hsl(var(--success))';

        const gapBtn = document.getElementById('btnGap');
        const gapOutput = document.getElementById('gapOutput');
        if (gapBtn && gapOutput) {
          gapBtn.addEventListener('click', async () => {
            (gapBtn as HTMLButtonElement).disabled = true;
            gapBtn.style.opacity = '0.5';
            gapOutput.style.display = 'block';
            gapOutput.textContent = 'Running AI competitive gap analysis...';
            try {
              const res = await fetch('/api/ai/competitor-gap', {
                method: 'POST',
                body: JSON.stringify({ domainA, domainB }),
                headers: { 'Content-Type': 'application/json' }
              });
              const result = await res.json();
              if (result.analysis) {
                gapOutput.innerHTML = marked.parse(result.analysis) as string;
              } else {
                gapOutput.textContent = 'Error: ' + (result.error || 'Unknown error');
              }
            } catch {
              gapOutput.textContent = 'Network error generating gap analysis.';
            }
            (gapBtn as HTMLButtonElement).disabled = false;
            gapBtn.style.opacity = '1';
          });
        }

      } catch (err: any) {
        status.innerText = 'Error: ' + (err.message || 'Failed to compare.');
        status.style.color = 'hsl(var(--danger))';
      }

      btn.disabled = false;
      btn.innerText = 'Compare Now';
    });
  </script>
</Layout>
