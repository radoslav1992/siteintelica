---
import Layout from '../layouts/Layout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');
---

<Layout title="Notifications" description="View alerts about tech stack changes, security events, and monitoring updates.">
  <div class="container page-content">
    <header class="page-header">
      <h1 class="text-gradient">Notifications</h1>
      <p class="text-secondary text-lg">Stay informed about changes to your monitored domains.</p>
      <button class="btn-secondary mark-all-btn" id="markAllBtn">Mark all as read</button>
    </header>

    <div id="notifList" class="notif-list">
      <div class="loading-state" id="loadingState">
        <div class="spinner"></div>
        <p class="text-secondary">Loading notifications...</p>
      </div>
    </div>

    <div id="emptyState" class="empty-state hidden">
      <div class="empty-icon">🔔</div>
      <h3>No notifications yet</h3>
      <p class="text-secondary">Start monitoring domains to receive change alerts here.</p>
    </div>
  </div>

  <style>
    .page-content { padding-top: 6rem; padding-bottom: 6rem; max-width: 700px; margin: 0 auto; }
    .page-header { text-align: center; margin-bottom: 2rem; }
    .page-header h1 { font-size: 2.5rem; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 0.5rem; }

    .mark-all-btn {
      margin-top: 0.75rem; padding: 0.4rem 1rem; font-size: 0.8rem;
      background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
      border-radius: var(--radius-sm); color: hsl(var(--text-secondary));
      cursor: pointer; transition: all 0.2s; font-weight: 600;
    }
    .mark-all-btn:hover { background: rgba(255,255,255,0.1); color: hsl(var(--text-primary)); }

    .notif-list { display: flex; flex-direction: column; gap: 0.5rem; }

    :global(.notif-card) {
      display: flex; gap: 1rem; padding: 1rem 1.25rem; transition: all 0.2s;
      border-left: 3px solid transparent;
    }
    :global(.notif-card.unread) {
      border-left-color: hsl(var(--accent-primary));
      background: hsla(var(--accent-primary), 0.03);
    }
    :global(.notif-icon) { font-size: 1.4rem; flex-shrink: 0; line-height: 1; }
    :global(.notif-body) { flex: 1; min-width: 0; }
    :global(.notif-title) { font-weight: 700; font-size: 0.9rem; color: hsl(var(--text-primary)); margin-bottom: 0.2rem; }
    :global(.notif-text) { font-size: 0.8rem; color: hsl(var(--text-secondary)); line-height: 1.5; }
    :global(.notif-time) { font-size: 0.7rem; color: hsl(var(--text-muted)); margin-top: 0.35rem; }
    :global(.notif-domain) {
      display: inline-block; padding: 0.1rem 0.4rem; border-radius: 3px;
      background: rgba(255,255,255,0.06); font-family: var(--font-mono); font-size: 0.72rem;
      color: hsl(var(--accent-primary)); margin-top: 0.25rem;
    }

    .loading-state, .empty-state { text-align: center; padding: 3rem 1rem; }
    .empty-icon { font-size: 3rem; margin-bottom: 1rem; opacity: 0.5; }
    .empty-state h3 { font-size: 1.2rem; margin-bottom: 0.5rem; }

    .spinner {
      width: 32px; height: 32px; border: 3px solid rgba(255,255,255,0.08);
      border-top-color: hsl(var(--accent-primary)); border-radius: 50%;
      animation: spin 0.8s linear infinite; margin: 0 auto 1rem;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>

  <script>
    const notifList = document.getElementById('notifList')!;
    const loadingState = document.getElementById('loadingState')!;
    const emptyState = document.getElementById('emptyState')!;
    const markAllBtn = document.getElementById('markAllBtn')!;

    const TYPE_ICONS: Record<string, string> = {
      monitor: '📡',
      tech_change: '🔄',
      security: '🛡️',
      performance: '⚡',
      ssl_expiry: '🔒',
      system: '⚙️',
    };

    async function loadNotifications() {
      try {
        const res = await fetch('/api/notifications');
        if (!res.ok) throw new Error('Failed to load');
        const data = await res.json();
        renderNotifications(data.notifications);
      } catch {
        loadingState.innerHTML = '<p class="text-danger">Failed to load notifications.</p>';
      }
    }

    function renderNotifications(notifications: any[]) {
      loadingState.remove();

      if (notifications.length === 0) {
        emptyState.classList.remove('hidden');
        return;
      }

      emptyState.classList.add('hidden');
      notifList.innerHTML = '';

      notifications.forEach((n: any) => {
        const card = document.createElement('div');
        card.className = `glass-panel notif-card ${n.is_read ? '' : 'unread'}`;

        const icon = TYPE_ICONS[n.type] || '🔔';
        const time = timeAgo(new Date(n.created_at));

        card.innerHTML = `
          <span class="notif-icon">${icon}</span>
          <div class="notif-body">
            <div class="notif-title">${n.title}</div>
            <div class="notif-text">${n.body}</div>
            ${n.domain ? `<span class="notif-domain">${n.domain}</span>` : ''}
            <div class="notif-time">${time}</div>
          </div>
        `;

        notifList.appendChild(card);
      });
    }

    function timeAgo(date: Date): string {
      const seconds = Math.floor((Date.now() - date.getTime()) / 1000);
      if (seconds < 60) return 'just now';
      const minutes = Math.floor(seconds / 60);
      if (minutes < 60) return `${minutes}m ago`;
      const hours = Math.floor(minutes / 60);
      if (hours < 24) return `${hours}h ago`;
      const days = Math.floor(hours / 24);
      if (days < 7) return `${days}d ago`;
      return date.toLocaleDateString();
    }

    markAllBtn.addEventListener('click', async () => {
      await fetch('/api/notifications', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'mark_read' }),
      });
      document.querySelectorAll('.notif-card.unread').forEach(el => el.classList.remove('unread'));
      markAllBtn.textContent = 'All read ✓';
    });

    loadNotifications();
  </script>
</Layout>
