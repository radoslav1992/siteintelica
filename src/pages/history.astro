---
import Layout from '../layouts/Layout.astro';
import { getRecentScans } from '../db/client';
export const prerender = false;

const scans = getRecentScans(100);

// Group scans by domain
const domainMap = new Map<string, { count: number; lastScanned: string }>();
scans.forEach(s => {
  const existing = domainMap.get(s.domain);
  if (existing) {
    existing.count++;
  } else {
    domainMap.set(s.domain, { count: 1, lastScanned: s.scanned_at });
  }
});
const domains = [...domainMap.entries()].map(([domain, info]) => ({ domain, ...info }));
---

<Layout title="Scan History">
  <div class="container" style="max-width:900px; margin:0 auto; padding:2rem 1rem;">
    <header style="text-align:center; margin-bottom:2rem;">
      <h1 style="font-size:2.2rem; font-weight:800;">📜 Scan History</h1>
      <p style="color:hsl(var(--text-secondary)); margin-top:0.5rem;">All previously scanned domains</p>
    </header>

    <div id="filter-bar" class="glass-panel" style="display:flex; gap:1rem; align-items:center; padding:0.75rem 1rem; margin-bottom:1.5rem; flex-wrap:wrap;">
      <input type="text" id="search-filter" placeholder="Filter domains..." 
             style="flex:1; min-width:200px; background:transparent; border:1px solid hsla(var(--text-primary),0.12); border-radius:8px; padding:0.5rem 0.75rem; color:hsl(var(--text-primary)); font-size:0.85rem;" />
      <span style="font-size:0.8rem; color:hsl(var(--text-secondary));">{domains.length} unique domains &middot; {scans.length} total scans</span>
    </div>

    <div id="history-list">
      {domains.length === 0 ? (
        <div class="glass-panel" style="text-align:center; padding:3rem;">
          <p style="font-size:1.1rem; font-weight:600;">No scans yet</p>
          <p style="color:hsl(var(--text-secondary)); margin-top:0.5rem;">
            Go to the <a href="/" style="color:hsl(var(--accent-primary));">Spy Tool</a> to scan your first website.
          </p>
        </div>
      ) : (
        domains.map((item) => (
          <div class="history-item glass-panel" data-domain={item.domain} style="display:flex; justify-content:space-between; align-items:center; padding:0.85rem 1.25rem; margin-bottom:0.75rem; border-radius:10px; transition:border-color 0.2s;">
            <div>
              <div style="font-weight:700; font-size:0.95rem;">{item.domain}</div>
              <div style="font-size:0.75rem; color:hsl(var(--text-secondary)); margin-top:2px;">
                Last scanned: {new Date(item.lastScanned + ' Z').toLocaleString()} &middot; {item.count} scan{item.count > 1 ? 's' : ''}
              </div>
            </div>
            <div style="display:flex; gap:0.5rem;">
              <a href={`/?scan=https://${item.domain}`} class="btn-action" style="font-size:0.75rem; padding:0.4rem 0.85rem; border-radius:6px; background:hsla(var(--accent-primary),0.15); color:hsl(var(--accent-primary)); text-decoration:none; font-weight:600; white-space:nowrap;">
                🔄 Re-scan
              </a>
            </div>
          </div>
        ))
      )}
    </div>
  </div>

  <style>
    .history-item { border-left: 3px solid transparent; }
    .history-item:hover { border-left-color: hsl(var(--accent-primary)); }
    .btn-action:hover { filter: brightness(1.2); }
  </style>

  <script>
    const filter = document.getElementById('search-filter') as HTMLInputElement;
    const items = document.querySelectorAll('.history-item');
    filter?.addEventListener('input', () => {
      const q = filter.value.toLowerCase();
      items.forEach(item => {
        const domain = (item as HTMLElement).dataset.domain || '';
        (item as HTMLElement).style.display = domain.includes(q) ? '' : 'none';
      });
    });
  </script>
</Layout>
