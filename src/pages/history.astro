---
import Layout from '../layouts/Layout.astro';
import { getRecentScans } from '../db/client';
export const prerender = false;

const scans = getRecentScans(100);

const domainMap = new Map<string, { count: number; lastScanned: string }>();
scans.forEach(s => {
  const existing = domainMap.get(s.domain);
  if (existing) {
    existing.count++;
  } else {
    domainMap.set(s.domain, { count: 1, lastScanned: s.scanned_at });
  }
});
const domains = [...domainMap.entries()].map(([domain, info]) => ({ domain, ...info }));
---

<Layout title="Scan History">
  <div class="container page-content">
    <header class="page-header">
      <h1 class="text-gradient">Scan History</h1>
      <p class="text-secondary">All previously scanned domains</p>
    </header>

    <div class="content-wrapper">
      <div class="glass-panel filter-bar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:hsl(var(--text-muted)); flex-shrink:0;">
          <circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
        <input type="text" id="search-filter" placeholder="Filter domains..." class="filter-input" />
        <span class="filter-stats">{domains.length} domains &middot; {scans.length} scans</span>
      </div>

      <div id="history-list">
        {domains.length === 0 ? (
          <div class="glass-panel empty-state">
            <p class="font-semibold text-lg">No scans yet</p>
            <p class="text-secondary mt-2">
              Go to the <a href="/" class="text-accent-primary font-semibold">Spy Tool</a> to scan your first website.
            </p>
          </div>
        ) : (
          domains.map((item) => (
            <div class="history-item glass-panel" data-domain={item.domain}>
              <div class="history-info">
                <div class="history-domain">{item.domain}</div>
                <div class="history-meta">
                  Last scanned: {new Date(item.lastScanned + ' Z').toLocaleString()} &middot; {item.count} scan{item.count > 1 ? 's' : ''}
                </div>
              </div>
              <a href={`/?scan=https://${item.domain}`} class="rescan-btn">
                Re-scan
              </a>
            </div>
          ))
        )}
      </div>
    </div>
  </div>

  <style>
    .page-content {
      padding-top: 6rem;
      padding-bottom: 6rem;
    }

    .page-header {
      text-align: center;
      margin-bottom: 2rem;
    }

    .page-header h1 {
      font-size: 2.25rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      margin-bottom: 0.5rem;
    }

    .content-wrapper {
      max-width: 800px;
      margin: 0 auto;
    }

    .filter-bar {
      display: flex;
      gap: 0.75rem;
      align-items: center;
      padding: 0.75rem 1rem;
      margin-bottom: 1.25rem;
    }

    .filter-input {
      flex: 1;
      min-width: 200px;
      background: transparent;
      border: none;
      color: hsl(var(--text-primary));
      font-size: 0.9rem;
      font-family: var(--font-sans);
      outline: none;
    }

    .filter-input::placeholder {
      color: hsl(var(--text-muted));
    }

    .filter-stats {
      font-size: 0.78rem;
      color: hsl(var(--text-muted));
      white-space: nowrap;
    }

    .empty-state {
      text-align: center;
      padding: 3rem;
    }

    .history-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.85rem 1.25rem;
      margin-bottom: 0.5rem;
      border-left: 3px solid transparent;
      transition: border-color var(--transition-fast);
    }

    .history-item:hover {
      border-left-color: hsl(var(--accent-primary));
    }

    .history-domain {
      font-weight: 700;
      font-size: 0.95rem;
    }

    .history-meta {
      font-size: 0.75rem;
      color: hsl(var(--text-secondary));
      margin-top: 2px;
    }

    .rescan-btn {
      font-size: 0.78rem;
      padding: 0.4rem 0.85rem;
      border-radius: var(--radius-sm);
      background: hsla(var(--accent-primary), 0.1);
      color: hsl(var(--accent-primary));
      text-decoration: none;
      font-weight: 600;
      white-space: nowrap;
      transition: all var(--transition-fast);
    }

    .rescan-btn:hover {
      background: hsla(var(--accent-primary), 0.2);
    }

    @media (max-width: 640px) {
      .history-item { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
      .filter-stats { display: none; }
    }
  </style>

  <script>
    const filter = document.getElementById('search-filter') as HTMLInputElement;
    const items = document.querySelectorAll('.history-item');
    filter?.addEventListener('input', () => {
      const q = filter.value.toLowerCase();
      items.forEach(item => {
        const domain = (item as HTMLElement).dataset.domain || '';
        (item as HTMLElement).style.display = domain.includes(q) ? '' : 'none';
      });
    });
  </script>
</Layout>
