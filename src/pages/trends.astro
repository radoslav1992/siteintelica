---
import Layout from '../layouts/Layout.astro';
import { getTrendsData } from '../db/client';

export const prerender = false;

// Fetch aggregated data from the local SQLite database
const trends = getTrendsData();

const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Global Tech Trends | SiteIntelica",
  "description": "Discover the most popular frontend frameworks, CMS platforms, and ad networks based on thousands of real-time website scans."
};
---

<Layout title="Global Tech Trends" description="Discover the most popular frontend frameworks, CMS platforms, and ad networks based on thousands of real-time website scans.">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  
  <div class="container pb-24">
    <header class="text-center pt-24 pb-12">
      <h1 class="text-gradient text-5xl md:text-6xl font-extrabold mb-4 tracking-tight">Global Tech Trends</h1>
      <p class="text-xl text-secondary max-w-2xl mx-auto mb-8">
        Aggregated insights from <strong style="color:hsl(var(--text-primary))">{trends.totalScans.toLocaleString()}</strong> recent website scans. Discover what the internet is built on today.
      </p>
    </header>

    <div class="trends-grid">
      <!-- Top Technologies -->
      <section class="glass-panel p-6 animate-fade-in" style="animation-delay: 0.1s;">
        <h2 class="category-title text-2xl mb-6 flex items-center gap-2">
           <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-primary"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
           Most Popular Technologies
        </h2>
        
        <div class="flex flex-col gap-4">
          {trends.topTechnologies.length > 0 ? trends.topTechnologies.map((tech, index) => {
             // Calculate percentage relative to the #1 item to draw a nice bar
             const maxCount = trends.topTechnologies[0].count || 1;
             const widthPercent = Math.max(5, (tech.count / maxCount) * 100);
             
             return (
              <div class="trend-item group">
                <div class="flex justify-between items-end mb-1">
                  <span class="font-semibold" style="color:hsl(var(--text-primary))">
                    <span class="text-secondary mr-2" style="font-size: 0.8em;">#{index + 1}</span>
                    {tech.name}
                  </span>
                  <span class="text-sm font-mono text-secondary group-hover:text-accent-primary transition-colors">{tech.count.toLocaleString()} scans</span>
                </div>
                <div class="progress-bg w-full h-2 rounded-full overflow-hidden" style="background: hsla(var(--text-primary), 0.1);">
                  <div class="progress-bar h-full rounded-full transition-all duration-1000 ease-out" 
                       style={`width: ${widthPercent}%; background: linear-gradient(90deg, hsl(var(--accent-primary)), hsl(var(--accent-secondary)));`}>
                  </div>
                </div>
              </div>
            );
          }) : (
            <div class="text-secondary text-center py-8">Not enough data collected yet. Scan more websites!</div>
          )}
        </div>
      </section>

      <!-- Top Categories -->
      <section class="glass-panel p-6 animate-fade-in" style="animation-delay: 0.2s;">
         <h2 class="category-title text-2xl mb-6 flex items-center gap-2">
           <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent-secondary"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
           Top Technology Categories
        </h2>
        
        <div class="flex flex-col gap-4">
          {trends.topCategories.length > 0 ? trends.topCategories.map((cat, index) => {
             const maxCount = trends.topCategories[0].count || 1;
             const widthPercent = Math.max(5, (cat.count / maxCount) * 100);
             
             return (
              <div class="trend-item group">
                <div class="flex justify-between items-end mb-1">
                  <span class="font-semibold" style="color:hsl(var(--text-primary))">
                    {cat.name}
                  </span>
                  <span class="text-sm font-mono text-secondary group-hover:text-accent-secondary transition-colors">{cat.count.toLocaleString()}</span>
                </div>
                 <div class="progress-bg w-full h-2 rounded-full overflow-hidden" style="background: hsla(var(--text-primary), 0.1);">
                  <div class="progress-bar h-full rounded-full transition-all duration-1000 ease-out" 
                       style={`width: ${widthPercent}%; background: hsl(var(--accent-secondary)); opacity: 0.8;`}>
                  </div>
                </div>
              </div>
            );
          }) : (
             <div class="text-secondary text-center py-8">Not enough data collected yet.</div>
          )}
        </div>
      </section>
    </div>
  </div>

  <style>
    .trends-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
      max-width: 1200px;
      margin: 0 auto;
    }
    
    @media (min-width: 1024px) {
      .trends-grid {
        grid-template-columns: 2fr 1fr;
      }
    }
    
    .category-title {
      border-bottom: 1px solid hsla(var(--text-primary), 0.1);
      padding-bottom: 1rem;
    }
    
    .flex { display: flex; }
    .flex-col { flex-direction: column; }
    .justify-between { justify-content: space-between; }
    .items-end { align-items: flex-end; }
    .items-center { align-items: center; }
    .gap-2 { gap: 0.5rem; }
    .gap-4 { gap: 1rem; }
    .mb-1 { margin-bottom: 0.25rem; }
    .mb-6 { margin-bottom: 1.5rem; }
    .mr-2 { margin-right: 0.5rem; }
    .py-8 { padding-top: 2rem; padding-bottom: 2rem; }
    
    .text-sm { font-size: 0.875rem; }
    .text-2xl { font-size: 1.5rem; }
    .font-semibold { font-weight: 600; }
    .font-mono { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace; }
    
    .w-full { width: 100%; }
    .h-2 { height: 0.5rem; }
    .h-full { height: 100%; }
    .rounded-full { border-radius: 9999px; }
    .overflow-hidden { overflow: hidden; }
    
    .transition-all { transition-property: all; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1); transition-duration: 150ms; }
    .transition-colors { transition-property: color, background-color, border-color, text-decoration-color, fill, stroke; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1); transition-duration: 150ms; }
    .duration-1000 { transition-duration: 1000ms; }
    .ease-out { transition-timing-function: cubic-bezier(0, 0, 0.2, 1); }
    
    .text-accent-primary { color: hsl(var(--accent-primary)); }
    .text-accent-secondary { color: hsl(var(--accent-secondary)); }
  </style>
  
  <script>
    // Simple animation for progress bars on load
    document.addEventListener('DOMContentLoaded', () => {
      setTimeout(() => {
        const bars = document.querySelectorAll('.progress-bar');
        bars.forEach(bar => {
          const w = (bar as HTMLElement).style.width;
          (bar as HTMLElement).style.width = '0%';
          setTimeout(() => {
            (bar as HTMLElement).style.width = w;
          }, 50);
        });
      }, 100);
    });
  </script>
</Layout>
