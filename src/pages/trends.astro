---
import Layout from '../layouts/Layout.astro';
import { getTrendsData } from '../db/client';

export const prerender = false;

const trends = getTrendsData();

const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Global Tech Trends | SiteIntelica",
  "description": "Discover the most popular frontend frameworks, CMS platforms, and ad networks based on thousands of real-time website scans."
};
---

<Layout title="Global Tech Trends" description="Discover the most popular frontend frameworks, CMS platforms, and ad networks based on thousands of real-time website scans.">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  
  <div class="container page-content">
    <header class="page-header">
      <h1 class="text-gradient">Global Tech Trends</h1>
      <p class="text-secondary text-lg">
        Aggregated insights from <strong style="color:hsl(var(--text-primary))">{trends.totalScans.toLocaleString()}</strong> recent website scans.
      </p>
    </header>

    <div class="trends-grid">
      <section class="glass-panel trend-section animate-fade-in" style="animation-delay: 0.05s;">
        <h2 class="section-title">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:hsl(var(--accent-primary))"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" /></svg>
          Most Popular Technologies
        </h2>
        
        <div class="trend-list">
          {trends.topTechnologies.length > 0 ? trends.topTechnologies.map((tech, index) => {
            const maxCount = trends.topTechnologies[0].count || 1;
            const widthPercent = Math.max(5, (tech.count / maxCount) * 100);
            return (
              <div class="trend-item">
                <div class="trend-item-header">
                  <span class="trend-name">
                    <span class="trend-rank">#{index + 1}</span>
                    {tech.name}
                  </span>
                  <span class="trend-count">{tech.count.toLocaleString()} scans</span>
                </div>
                <div class="progress-bg">
                  <div class="progress-bar progress-primary" style={`width: ${widthPercent}%;`}></div>
                </div>
              </div>
            );
          }) : (
            <div class="text-secondary text-center py-8">Not enough data collected yet. Scan more websites!</div>
          )}
        </div>
      </section>

      <section class="glass-panel trend-section animate-fade-in" style="animation-delay: 0.1s;">
        <h2 class="section-title">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:hsl(var(--accent-secondary))"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
          Top Technology Categories
        </h2>
        
        <div class="trend-list">
          {trends.topCategories.length > 0 ? trends.topCategories.map((cat, index) => {
            const maxCount = trends.topCategories[0].count || 1;
            const widthPercent = Math.max(5, (cat.count / maxCount) * 100);
            return (
              <div class="trend-item">
                <div class="trend-item-header">
                  <span class="trend-name">{cat.name}</span>
                  <span class="trend-count">{cat.count.toLocaleString()}</span>
                </div>
                <div class="progress-bg">
                  <div class="progress-bar progress-secondary" style={`width: ${widthPercent}%;`}></div>
                </div>
              </div>
            );
          }) : (
            <div class="text-secondary text-center py-8">Not enough data collected yet.</div>
          )}
        </div>
      </section>
    </div>
  </div>

  <style>
    .page-content {
      padding-top: 6rem;
      padding-bottom: 6rem;
    }

    .page-header {
      text-align: center;
      margin-bottom: 2.5rem;
    }

    .page-header h1 {
      font-size: 2.5rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      margin-bottom: 0.5rem;
    }

    .trends-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    @media (min-width: 1024px) {
      .trends-grid {
        grid-template-columns: 3fr 2fr;
      }
    }

    .trend-section {
      padding: 1.75rem;
    }

    .section-title {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1.15rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .trend-list {
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
    }

    .trend-item-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 0.3rem;
    }

    .trend-name {
      font-weight: 600;
      font-size: 0.9rem;
    }

    .trend-rank {
      color: hsl(var(--text-muted));
      font-size: 0.78rem;
      margin-right: 0.4rem;
    }

    .trend-count {
      font-size: 0.78rem;
      font-family: var(--font-mono);
      color: hsl(var(--text-secondary));
    }

    .progress-bg {
      width: 100%;
      height: 6px;
      border-radius: 3px;
      background: rgba(255, 255, 255, 0.06);
      overflow: hidden;
    }

    .progress-bar {
      height: 100%;
      border-radius: 3px;
      transition: width 1s ease-out;
    }

    .progress-primary {
      background: linear-gradient(90deg, hsl(var(--accent-primary)), hsl(var(--accent-secondary)));
    }

    .progress-secondary {
      background: hsl(var(--accent-secondary));
      opacity: 0.8;
    }
  </style>
  
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      setTimeout(() => {
        document.querySelectorAll('.progress-bar').forEach(bar => {
          const el = bar as HTMLElement;
          const w = el.style.width;
          el.style.width = '0%';
          setTimeout(() => { el.style.width = w; }, 50);
        });
      }, 100);
    });
  </script>
</Layout>
