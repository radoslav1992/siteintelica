---
import Layout from '../../layouts/Layout.astro';
import { getTrendsData, getTechAggregation } from '../../db/client';

export const prerender = false;

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/trends');

const techName = decodeURIComponent(slug).replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
const trends = getTrendsData();
const matchedTech = trends.topTechnologies.find(
  t => t.name.toLowerCase() === techName.toLowerCase() ||
       t.name.toLowerCase().replace(/[.\s]/g, '-') === slug.toLowerCase()
);

const displayName = matchedTech?.name || techName;
const aggregation = getTechAggregation(displayName);
const globalShare = trends.totalScans > 0
  ? ((aggregation.totalSites / trends.totalScans) * 100).toFixed(1)
  : '0';
---

<Layout title={`${displayName} — Technology Deep Dive`} description={`See how ${displayName} is used across websites: adoption rate, companion technologies, and performance benchmarks.`}>
  <div class="container page-content">
    <header class="page-header">
      <h1 class="text-gradient">{displayName}</h1>
      <p class="text-secondary text-lg">Technology Deep Dive — based on {trends.totalScans.toLocaleString()} scans</p>
    </header>

    {aggregation.totalSites === 0 ? (
      <div class="glass-panel" style="padding:2rem; text-align:center;">
        <p class="text-secondary">No scan data found for "{displayName}". <a href="/" style="color:hsl(var(--accent-primary));">Scan a site using it</a></p>
      </div>
    ) : (
      <div class="deep-dive-grid">
        <div class="glass-panel stat-card animate-fade-in">
          <div class="stat-value text-gradient">{aggregation.totalSites}</div>
          <div class="stat-label">Total detections</div>
        </div>

        <div class="glass-panel stat-card animate-fade-in" style="animation-delay:0.05s;">
          <div class="stat-value text-gradient">{aggregation.uniqueDomains}</div>
          <div class="stat-label">Unique domains</div>
        </div>

        <div class="glass-panel stat-card animate-fade-in" style="animation-delay:0.1s;">
          <div class="stat-value text-gradient">{globalShare}%</div>
          <div class="stat-label">Adoption rate</div>
        </div>

        <div class="glass-panel stat-card animate-fade-in" style="animation-delay:0.15s;">
          <div class="stat-value" style={`color: ${(aggregation.avgPerformance ?? 0) >= 80 ? '#00e676' : (aggregation.avgPerformance ?? 0) >= 50 ? '#ffa726' : '#ff4b4b'};`}>
            {aggregation.avgPerformance ?? '—'}
          </div>
          <div class="stat-label">Avg. performance score</div>
        </div>

        {aggregation.topCompanions.length > 0 && (
          <div class="glass-panel companions-card animate-fade-in" style="animation-delay:0.2s;">
            <h2 class="section-title">Most Common Companion Technologies</h2>
            <p class="text-secondary text-sm mb-4">Technologies frequently found alongside {displayName}</p>
            <div class="companion-list">
              {aggregation.topCompanions.map((comp, i) => {
                const maxCount = aggregation.topCompanions[0].count || 1;
                const pct = Math.max(5, (comp.count / maxCount) * 100);
                return (
                  <div class="companion-item">
                    <div class="companion-header">
                      <a href={`/tech/${comp.name.toLowerCase().replace(/[\s.]/g, '-')}`} class="companion-name">{comp.name}</a>
                      <span class="companion-count">{comp.count}x</span>
                    </div>
                    <div class="progress-bg">
                      <div class="progress-bar" style={`width: ${pct}%;`}></div>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        {aggregation.perfDistribution.length > 0 && (
          <div class="glass-panel animate-fade-in" style="padding:1.5rem; animation-delay:0.25s;">
            <h2 class="section-title">Performance Distribution</h2>
            <div class="perf-histogram" id="perfHistogram">
              <canvas id="perfChart" height="160"></canvas>
            </div>
          </div>
        )}
      </div>
    )}
  </div>

  <style>
    .page-content { padding-top: 6rem; padding-bottom: 6rem; }
    .page-header { text-align: center; margin-bottom: 2.5rem; }
    .page-header h1 { font-size: 2.5rem; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 0.5rem; }

    .deep-dive-grid { max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
    .stat-card { padding: 1.5rem; text-align: center; }
    .stat-value { font-size: 2rem; font-weight: 800; line-height: 1.2; }
    .stat-label { font-size: 0.78rem; color: hsl(var(--text-secondary)); margin-top: 0.25rem; }

    .companions-card { grid-column: 1 / -1; padding: 1.5rem; }
    .section-title { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.5rem; padding-bottom: 0.75rem; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .companion-list { display: flex; flex-direction: column; gap: 0.6rem; }
    .companion-header { display: flex; justify-content: space-between; margin-bottom: 0.2rem; }
    .companion-name { font-size: 0.88rem; font-weight: 600; text-decoration: none; color: hsl(var(--text-primary)); transition: color 0.15s; }
    .companion-name:hover { color: hsl(var(--accent-primary)); }
    .companion-count { font-size: 0.75rem; font-family: var(--font-mono); color: hsl(var(--text-secondary)); }
    .progress-bg { width: 100%; height: 5px; border-radius: 3px; background: rgba(255,255,255,0.06); overflow: hidden; }
    .progress-bar { height: 100%; border-radius: 3px; background: linear-gradient(90deg, hsl(var(--accent-primary)), hsl(var(--accent-secondary))); transition: width 0.8s ease-out; }

    .perf-histogram { position: relative; min-height: 160px; }

    @media (max-width: 640px) {
      .deep-dive-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>

  <script define:vars={{ perfDistribution: aggregation.perfDistribution }}>
    function drawHistogram() {
      const canvas = document.getElementById('perfChart');
      if (!canvas || !perfDistribution.length) return;
      const ctx = canvas.getContext('2d');
      const dpr = window.devicePixelRatio || 1;
      const rect = canvas.parentElement.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = 160 * dpr;
      canvas.style.width = rect.width + 'px';
      canvas.style.height = '160px';
      ctx.scale(dpr, dpr);

      const W = rect.width, H = 160;
      const pad = { top: 10, right: 10, bottom: 25, left: 35 };

      const buckets = Array(10).fill(0);
      perfDistribution.forEach(s => {
        const idx = Math.min(Math.floor(s / 10), 9);
        buckets[idx]++;
      });
      const maxBucket = Math.max(...buckets, 1);

      ctx.clearRect(0, 0, W, H);

      const barW = (W - pad.left - pad.right) / 10;
      buckets.forEach((count, i) => {
        const barH = (count / maxBucket) * (H - pad.top - pad.bottom);
        const x = pad.left + i * barW;
        const y = H - pad.bottom - barH;
        const color = i >= 8 ? '#00e676' : i >= 5 ? '#ffa726' : '#ff4b4b';
        ctx.fillStyle = color + '88';
        ctx.fillRect(x + 2, y, barW - 4, barH);

        ctx.fillStyle = 'rgba(255,255,255,0.4)';
        ctx.font = '9px Inter, sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText(`${i * 10}-${i * 10 + 9}`, x + barW / 2, H - 8);
        if (count > 0) ctx.fillText(count.toString(), x + barW / 2, y - 4);
      });
    }
    drawHistogram();
    window.addEventListener('resize', drawHistogram);
  </script>
</Layout>
