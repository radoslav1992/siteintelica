        title.innerHTML = `Recently Scanned Sites <span class="badge" style="font-size:0.6rem; margin-left:8px; background:hsla(var(--accent-primary), 0.2); color:hsl(var(--accent-primary))">DISCOVERY</span>`;
        
        const listContainer = document.createElement('div');
        listContainer.style.display = 'flex';
        listContainer.style.gap = '1rem';
        listContainer.style.flexWrap = 'wrap';
        
        data.similarSites.forEach(site => {
            const btn = document.createElement('button');
            btn.className = 'badge';
            btn.style.cursor = 'pointer';
            btn.style.padding = '0.5rem 1rem';
            btn.style.fontSize = '0.9rem';
            btn.innerHTML = `<img src="https://logo.clearbit.com/${site}" width="16" height="16" onerror="this.style.display='none'" style="margin-right:8px; border-radius:50%; vertical-align:middle;"/> ${site}`;
            
            // Allow clicking a similar site to instantly scan it
            btn.onclick = () => {
                urlInput.value = `https://${site}`;
                form.dispatchEvent(new Event('submit'));
                window.scrollTo({ top: 0, behavior: 'smooth' });
            };
            
            listContainer.appendChild(btn);
        });

        similarCard.appendChild(title);
        similarCard.appendChild(listContainer);
        resultsSection.appendChild(similarCard);
      }

      resultsSection.classList.remove('hidden');
    }

    // Initialize FAQ accordions
    initFAQ();
  </script>
</Layout>
