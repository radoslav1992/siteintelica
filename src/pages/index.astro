---
import Layout from '../layouts/Layout.astro';
export const prerender = false;

const schemaData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "SiteIntelica",
  "operatingSystem": "Web",
  "applicationCategory": "DeveloperApplication",
  "description": "Advanced tech stack analyzer and competitor intelligence tool. Reveal exactly how a website is built and monetized.",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<Layout title="The Ultimate Tech Stack 'Spy' Tool">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  <div class="container">
    <header class="hero text-center">
      <div class="hero-orbs">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
      </div>
      
      <div class="hero-content">
        <div class="trust-badge">
          <span class="trust-dot"></span>
          Trusted by 1,000+ developers & marketers
        </div>

        <h1 class="text-gradient hero-title">SiteIntelica</h1>
        <p class="hero-subtitle">
          X-Ray any website. Reveal exactly how it's built and how it makes money.
        </p>

        <div class="feature-pills">
          <span class="feature-pill">Tech Stack</span>
          <span class="feature-pill">Security Grade</span>
          <span class="feature-pill">AI Analysis</span>
          <span class="feature-pill">SEO & DNS</span>
          <span class="feature-pill">Performance</span>
        </div>
        
        <form id="analyze-form" class="input-group glass-panel p-2" style="max-width:600px; margin:0 auto;">
          <input 
            type="url" 
            id="url-input" 
            class="search-input" 
            placeholder="Enter a URL (e.g., https://stripe.com)" 
            required 
            pattern="https?://.*"
          />
          <button type="submit" id="submit-btn" class="btn-primary">
            <span id="btn-text">Analyze</span>
            <span id="btn-loader" class="loader" style="display: none;"></span>
          </button>
        </form>
        <div id="error-message" class="error-msg text-sm hidden"></div>
        <div id="history-message" class="text-secondary mt-2 text-sm hidden"></div>
        
        <button id="download-pdf-btn" class="btn-secondary text-sm hidden" style="margin-top:1.5rem;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
          Download PDF Report
        </button>
      </div>
    </header>

    <section id="results-section" class="results-grid hidden pb-24">
      <!-- Results will be injected here via JavaScript -->
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
      <h2 class="faq-title">Frequently Asked Questions</h2>
      
      <div class="faq-item">
        <button class="faq-question">
          What exactly does SiteIntelica do?
          <svg class="faq-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        </button>
        <div class="faq-answer">
          <div class="faq-answer-inner">
            We act as an "X-Ray" for websites. By entering a URL, SiteIntelica scans the code, headers, and DOM to reveal the exact technology stack powering the site—including content management systems (CMS), modern frontend frameworks like Astro and React, analytics tools, and ad networks.
          </div>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question">
          Is the analysis accurate in real-time?
          <svg class="faq-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        </button>
        <div class="faq-answer">
          <div class="faq-answer-inner">
            Yes! When you click "Analyze," our server spins up a dedicated scraping process that actively visits the website, reads its current code and headers, and matches them against thousands of technology signatures.
          </div>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question">
          Can I see what ad networks a competitor uses?
          <svg class="faq-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        </button>
        <div class="faq-answer">
          <div class="faq-answer-inner">
            Absolutely. Our scanner identifies dozens of different marketing, remarketing, and ad network pixels so you can tell exactly how a competitor might be buying traffic or monetizing their audience.
          </div>
        </div>
      </div>
    </section>
  </div>

  <style>
    .hero {
      min-height: 55vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      position: relative;
      overflow: hidden;
      padding: 6rem 0 4rem;
    }
    
    .hero-orbs {
      position: absolute;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
    }

    .orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(100px);
      opacity: 0.2;
    }

    .orb-1 {
      width: 420px;
      height: 420px;
      background: hsl(var(--accent-primary));
      top: -120px;
      right: -80px;
      animation: orbit1 14s ease-in-out infinite;
    }

    .orb-2 {
      width: 350px;
      height: 350px;
      background: hsl(var(--accent-secondary));
      bottom: -100px;
      left: -60px;
      animation: orbit2 18s ease-in-out infinite;
    }

    .orb-3 {
      width: 200px;
      height: 200px;
      background: hsl(var(--accent-warm));
      top: 40%;
      left: 50%;
      animation: orbit3 20s ease-in-out infinite;
      opacity: 0.1;
    }

    @keyframes orbit1 {
      0%, 100% { transform: translate(0, 0); }
      50% { transform: translate(-50px, 50px); }
    }

    @keyframes orbit2 {
      0%, 100% { transform: translate(0, 0); }
      50% { transform: translate(40px, -40px); }
    }

    @keyframes orbit3 {
      0%, 100% { transform: translate(-50%, -50%); }
      50% { transform: translate(-30%, -70%); }
    }

    .hero-content {
      position: relative;
      z-index: 2;
    }

    .trust-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: hsla(var(--accent-primary), 0.08);
      border: 1px solid hsla(var(--accent-primary), 0.2);
      border-radius: 99px;
      padding: 0.35rem 1rem;
      font-size: 0.78rem;
      color: hsl(var(--accent-primary));
      font-weight: 600;
      margin-bottom: 1.5rem;
    }

    .trust-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: hsl(var(--accent-primary));
      animation: pulse-dot 2s ease-in-out infinite;
    }

    @keyframes pulse-dot {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.8); }
    }

    .hero-title {
      font-size: 3.5rem;
      font-weight: 900;
      letter-spacing: -0.04em;
      margin-bottom: 0.75rem;
      line-height: 1.1;
    }

    @media (min-width: 768px) {
      .hero-title { font-size: 5rem; }
    }

    .hero-subtitle {
      font-size: 1.15rem;
      color: hsl(var(--text-secondary));
      max-width: 36rem;
      margin: 0 auto 1.75rem;
      line-height: 1.6;
    }

    @media (min-width: 768px) {
      .hero-subtitle { font-size: 1.35rem; }
    }

    .feature-pills {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.4rem;
      margin-bottom: 2rem;
    }

    .feature-pill {
      display: inline-flex;
      align-items: center;
      padding: 0.3rem 0.75rem;
      border-radius: 99px;
      font-size: 0.75rem;
      font-weight: 600;
      color: hsl(var(--text-secondary));
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.07);
      transition: all 0.25s ease;
    }

    .feature-pill:hover {
      color: hsl(var(--accent-primary));
      border-color: hsla(var(--accent-primary), 0.3);
      background: hsla(var(--accent-primary), 0.06);
    }

    .error-msg {
      color: hsl(var(--danger));
      margin-top: 1rem;
    }

    /* Bento Grid Layout for Results */
    .results-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1.25rem;
      width: 100%;
      max-width: 1000px;
      margin: 2rem auto 0;
    }
    
    :global(.category-card) {
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    
    :global(.category-title) {
      font-size: 1.1rem;
      font-weight: 700;
      color: hsl(var(--text-primary));
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      padding-bottom: 0.5rem;
      margin-bottom: 0.5rem;
    }
    
    :global(.tech-list) {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }
    
    @media (max-width: 768px) {
      .results-grid { grid-template-columns: 1fr; }
      .orb { opacity: 0.1; }
    }

    .report-section {
      grid-column: 1 / -1;
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: var(--radius-md);
      overflow: hidden;
      background: rgba(255, 255, 255, 0.015);
    }

    .report-section summary {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.85rem 1.25rem;
      cursor: pointer;
      font-size: 0.95rem;
      font-weight: 700;
      color: hsl(var(--text-primary));
      list-style: none;
      user-select: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.04);
      transition: background var(--transition-fast);
    }

    .report-section summary:hover { background: rgba(255, 255, 255, 0.025); }
    .report-section summary::-webkit-details-marker { display: none; }

    .report-section summary::after {
      content: '▸';
      margin-left: auto;
      font-size: 0.85rem;
      transition: transform 0.25s;
      color: hsl(var(--text-muted));
    }

    .report-section[open] summary::after { transform: rotate(90deg); }

    .report-section .section-body {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1rem;
      padding: 1rem;
    }

    .report-section .section-badge {
      font-size: 0.6rem;
      padding: 2px 8px;
      border-radius: 99px;
      background: hsla(var(--accent-primary), 0.1);
      color: hsl(var(--accent-primary));
    }

    @media (max-width: 768px) {
      .report-section .section-body { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    import { initFAQ } from '../scripts/faq.js';
    
    // Dynamically load html2pdf
    const script = document.createElement('script');
    script.src = 'https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js';
    document.head.appendChild(script);

    const form = document.getElementById('analyze-form') as HTMLFormElement;
    const urlInput = document.getElementById('url-input') as HTMLInputElement;
    const submitBtn = document.getElementById('submit-btn');
    const btnText = document.getElementById('btn-text');
    const btnLoader = document.getElementById('btn-loader');
    const resultsSection = document.getElementById('results-section');
    const errorMessage = document.getElementById('error-message');
    const historyMessage = document.getElementById('history-message');
    const downloadPdfBtn = document.getElementById('download-pdf-btn');

    let currentScanUrl = '';

    downloadPdfBtn?.addEventListener('click', () => {
        if (!window.html2pdf) {
            alert('PDF library is still loading, please try again in a moment.');
            return;
        }
        const element = document.getElementById('results-section');
        const opt = {
          margin:       0.5,
          filename:     `SiteIntelica_Report_${currentScanUrl.replace(/[^a-z0-9]/gi, '_')}.pdf`,
          image:        { type: 'jpeg', quality: 0.98 },
          html2canvas:  { scale: 2, useCORS: true, backgroundColor: '#0f1117' },
          jsPDF:        { unit: 'in', format: 'a4', orientation: 'portrait' }
        };
        
        const originalBg = element.style.background;
        element.style.background = '#0f1117';
        element.style.padding = '1rem';
        
        window.html2pdf().set(opt).from(element).save().then(() => {
            element.style.background = originalBg;
            element.style.padding = '';
        });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const url = urlInput.value;
      if (!url) return;

      currentScanUrl = new URL(url).hostname;

      // UI Loading State
      submitBtn.setAttribute('disabled', 'true');
      submitBtn.style.opacity = '0.7';
      btnText.style.display = 'none';
      btnLoader.style.display = 'inline-block';
      resultsSection.innerHTML = '';
      resultsSection.classList.add('hidden');
      errorMessage.classList.add('hidden');
      historyMessage.classList.add('hidden');
      downloadPdfBtn.classList.add('hidden');
      
      try {
        const response = await fetch('/api/analyze', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url })
        });
        
        if (!response.ok) {
          throw new Error('Failed to analyze the website. Please check the URL and try again.');
        }
        
        const data = await response.json();
        renderResults(data);
        downloadPdfBtn.classList.remove('hidden');
        
      } catch (error) {
        console.error('Error:', error);
        errorMessage.textContent = error.message;
        errorMessage.classList.remove('hidden');
      } finally {
        // Reset UI
        submitBtn.removeAttribute('disabled');
        submitBtn.style.opacity = '1';
        btnText.style.display = 'inline';
        btnLoader.style.display = 'none';
      }
    });

    // Auto-scan from Chrome Extension or URL Parameter
    window.addEventListener('DOMContentLoaded', () => {
      const params = new URLSearchParams(window.location.search);
      const scanUrl = params.get('scan');
      if (scanUrl) {
         urlInput.value = scanUrl;
         form.dispatchEvent(new Event('submit'));
         
         // Clean up URL so refresh doesn't trigger it again
         const url = new URL(window.location.href);
         url.searchParams.delete('scan');
         window.history.replaceState({}, document.title, url.toString());
      }
    });
    
    function renderResults(data) {
      resultsSection.innerHTML = '';
      
      if (data.historicalTimestamp) {
          const date = new Date(data.historicalTimestamp + ' Z').toLocaleString();
          historyMessage.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline; margin-right:4px; vertical-align:middle"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> Previous scan found from: ${date}. Showing current fresh results.`;
          historyMessage.classList.remove('hidden');
      }
      
      if (!data || !data.technologies || data.technologies.length === 0) {
        resultsSection.innerHTML = '<div class="glass-panel p-2 category-card animate-fade-in"><p>No technologies could be detected for this URL.</p></div>';
        resultsSection.classList.remove('hidden');
        return;
      }

      let delay = 0;

      // ─── Section Helper ───
      function createSection(icon, title, defaultOpen = false, badgeText = '') {
        const details = document.createElement('details');
        details.className = 'report-section';
        if (defaultOpen) details.open = true;
        const summary = document.createElement('summary');
        summary.innerHTML = `${icon} ${title}${badgeText ? ` <span class="section-badge">${badgeText}</span>` : ''}`;
        const body = document.createElement('div');
        body.className = 'section-body';
        details.appendChild(summary);
        details.appendChild(body);
        return { el: details, body };
      }

      // ─── Create All Sections ───
      const secOverview     = createSection('🔍', 'Overview', true);
      const secPerformance  = createSection('⚡', 'Performance & SEO', true);
      const secNetwork      = createSection('🌐', 'Network & DNS');
      const secBusiness     = createSection('📊', 'Business Intelligence', true, '★ PREMIUM');
      const secCrawl        = createSection('🕷️', 'Crawlability', false, '★ PREMIUM');
      const secSecurity     = createSection('🛡️', 'Security & Privacy');
      const secSocial       = createSection('📱', 'Social & Marketing');
      const secAI           = createSection('🤖', 'AI Intelligence Suite', true, '★ PREMIUM');

      // 0. Historical Tech Stack Diff Card
      if (data.historicalDiff && (data.historicalDiff.added.length > 0 || data.historicalDiff.removed.length > 0)) {
        const diffCard = document.createElement('div');
        diffCard.className = 'glass-panel category-card animate-fade-in';
        diffCard.style.animationDelay = `${delay}s`;
        diffCard.style.borderLeft = '3px solid hsl(var(--accent-primary))';
        
        const title = document.createElement('h3');
        title.className = 'category-title';
        title.innerHTML = `Timeline Changes <span class="badge" style="font-size:0.6rem; margin-left:8px; background:hsla(var(--accent-primary), 0.2); color:hsl(var(--accent-primary))">INTELLIGENCE</span>`;
        
        const list = document.createElement('div');
        list.className = 'tech-list';
        list.style.flexDirection = 'column';
        list.style.gap = '0.5rem';
        
        const lastDate = new Date(data.historicalDiff.lastScanDate + ' Z').toLocaleDateString();
        list.innerHTML += `<div style="font-size:0.8rem; color:hsl(var(--text-secondary)); margin-bottom:0.5rem;">Changes detected since last scan on ${lastDate}:</div>`;
        
        data.historicalDiff.added.forEach(tech => {
            list.innerHTML += `<div style="display:flex; align-items:center; gap:0.5rem; color:#00e676; font-weight:600; font-size:0.9rem;">
                <div style="width:18px; height:18px; border-radius:50%; background:rgba(0,230,118,0.1); display:flex; align-items:center; justify-content:center;">+</div>
                Detected ${tech}
            </div>`;
        });
        
        data.historicalDiff.removed.forEach(tech => {
            list.innerHTML += `<div style="display:flex; align-items:center; gap:0.5rem; color:#ff4b4b; font-weight:600; font-size:0.9rem; opacity:0.8;">
                <div style="width:18px; height:18px; border-radius:50%; background:rgba(255,75,75,0.1); display:flex; align-items:center; justify-content:center;">-</div>
                Removed ${tech}
            </div>`;
        });
        
        diffCard.appendChild(title);
        diffCard.appendChild(list);
        secOverview.body.appendChild(diffCard);
        delay += 0.1;
      }

      // 0.5 Visual Site Preview Card
      if (data.screenshotUrl) {
        const previewCard = document.createElement('div');
        previewCard.className = 'glass-panel category-card animate-fade-in';
        previewCard.style.animationDelay = `${delay}s`;
        
        const title = document.createElement('h3');
        title.className = 'category-title';
        title.innerHTML = `Visual Preview <span class="badge" style="font-size:0.6rem; margin-left:8px; background:hsla(var(--accent-secondary), 0.2); color:hsl(var(--accent-secondary))">LIVE</span>`;
        
        const imgContainer = document.createElement('div');
        imgContainer.style.width = '100%';
        imgContainer.style.height = '180px';
        imgContainer.style.borderRadius = '0.5rem';
        imgContainer.style.overflow = 'hidden';
        imgContainer.style.border = '1px solid hsla(var(--text-primary), 0.1)';
        imgContainer.style.position = 'relative';

        const img = document.createElement('img');
        img.src = data.screenshotUrl;
        img.style.width = '100%';
        img.style.height = '100%';
        img.style.objectFit = 'cover';
        img.style.objectPosition = 'top center';
        img.alt = `Screenshot of ${currentScanUrl}`;
        img.onerror = () => { imgContainer.style.display = 'none'; }; // Hide if microlink fails

        imgContainer.appendChild(img);
        previewCard.appendChild(title);
        previewCard.appendChild(imgContainer);
        secOverview.body.appendChild(previewCard);
        delay += 0.1;
      }

      // 0.6 Security Grade Card
      if (data.securityGrade) {
        const gradeColors = { 'A': '#00e676', 'B': '#66bb6a', 'C': '#ffa726', 'D': '#ff7043', 'F': '#ff4b4b' };
        const gradeColor = gradeColors[data.securityGrade.grade] || '#ff4b4b';
        
        const gradeCard = document.createElement('div');
        gradeCard.className = 'glass-panel category-card animate-fade-in';
        gradeCard.style.animationDelay = `${delay}s`;
        
        const title = document.createElement('h3');
        title.className = 'category-title';
        title.innerHTML = `Security Grade <span class="badge" style="font-size:0.6rem; margin-left:8px; background:${gradeColor}22; color:${gradeColor}">AUDIT</span>`;
        
        const content = document.createElement('div');
        content.innerHTML = `
          <div style="display:flex; align-items:center; gap:1.5rem; margin-bottom:1rem;">
            <div style="width:64px; height:64px; border-radius:12px; background:${gradeColor}22; border:2px solid ${gradeColor}; display:flex; align-items:center; justify-content:center; font-size:2rem; font-weight:800; color:${gradeColor};">${data.securityGrade.grade}</div>
            <div style="flex:1;">
              <div style="font-size:0.85rem; color:hsl(var(--text-secondary)); margin-bottom:4px;">Security Score: ${data.securityGrade.score}/100</div>
              <div style="width:100%; height:8px; background:hsla(var(--text-primary), 0.1); border-radius:4px; overflow:hidden;">
                <div style="width:${data.securityGrade.score}%; height:100%; background:${gradeColor}; border-radius:4px; transition:width 1s ease;"></div>
              </div>
            </div>
          </div>
          ${data.securityGrade.recommendations.length > 0 ? `
            <div style="font-size:0.8rem; color:hsl(var(--text-secondary));">
              ${data.securityGrade.recommendations.map(r => `<div style="padding:3px 0; border-bottom:1px solid hsla(var(--text-primary), 0.05);">⚠️ ${r}</div>`).join('')}
            </div>
          ` : '<div style="color:#00e676; font-size:0.85rem;">✅ All critical security headers are present.</div>'}
        `;
        
        gradeCard.appendChild(title);
        gradeCard.appendChild(content);
        secOverview.body.appendChild(gradeCard);
        delay += 0.1;
      }

      // 1. Social Links Card
      if (data.socials && data.socials.length > 0) {
        const socialCard = document.createElement('div');
        socialCard.className = 'glass-panel category-card animate-fade-in';
        socialCard.style.animationDelay = `${delay}s`;
        
        const title = document.createElement('h3');
        title.className = 'category-title';
        title.textContent = 'Social & Contact';
        
        const list = document.createElement('div');
        list.className = 'tech-list';
        
        data.socials.forEach(link => {
          const badge = document.createElement('a');
          badge.href = link;
          badge.target = '_blank';
          badge.className = 'badge';
          badge.style.textDecoration = 'none';
          
          try {
            const domain = new URL(link).hostname.replace('www.', '');
            const iconHtml = `<img src="https://logo.clearbit.com/${domain}" width="16" height="16" onerror="this.style.display='none'" style="margin-right: 6px; border-radius: 50%;" alt=""/>`;
            badge.innerHTML = `${iconHtml}${domain}`;
          } catch(e) {
            badge.textContent = 'Link';
          }
          list.appendChild(badge);
        });
        
        socialCard.appendChild(title);
