---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const blogEntries = await getCollection('blog');
const sortedEntries = blogEntries.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

export const prerender = false;
---

<Layout 
  title="Blog & SEO Insights" 
  description="Read our latest articles on tech stack analysis, email deliverability, and technical SEO strategies."
>
  <div class="container pt-24 pb-24">
    <header class="text-center mb-16">
      <h1 class="text-5xl font-extrabold mb-4 text-gradient tracking-tight">Technical Insights</h1>
      <p class="text-xl text-secondary max-w-2xl mx-auto">
        Learn how to reverse-engineer competitor websites, fix email deliverability, and optimize your technical SEO structure.
      </p>
    </header>

    <div class="blog-grid">
      {sortedEntries.map(post => (
        <a href={`/blog/${post.id}`} class="blog-card glass-panel flex flex-col h-full animate-fade-in no-underline">
          <div class="p-6 flex-grow flex flex-col">
            <div class="mb-3 flex items-center gap-2 flex-wrap">
              {post.data.tags?.map(tag => (
                <span class="badge text-xs">{tag}</span>
              ))}
            </div>
            <h2 class="text-2xl font-bold mb-3 text-white group-hover:text-accent-primary transition-colors">{post.data.title}</h2>
            <p class="text-secondary mb-6 flex-grow line-clamp-3">{post.data.description}</p>
            
            <div class="mt-auto pt-4 border-t border-white/5 flex justify-between items-center text-sm text-secondary">
              <span>{post.data.author}</span>
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <style>
    .mb-16 { margin-bottom: 4rem; }
    .mb-3 { margin-bottom: 0.75rem; }
    .mt-auto { margin-top: auto; }
    .pt-4 { padding-top: 1rem; }
    .flex-grow { flex-grow: 1; }
    .h-full { height: 100%; }
    .text-white { color: hsl(var(--text-primary)); }

    .border-t { border-top-width: 1px; border-top-style: solid; }
    .border-white\/5 { border-color: rgba(255, 255, 255, 0.05); }
    .no-underline { text-decoration: none; }

    .line-clamp-3 {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;  
      overflow: hidden;
    }
    
    .blog-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 2rem;
      max-width: 1100px;
      margin: 0 auto;
    }
    
    .blog-card {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    
    .blog-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px -10px hsla(var(--accent-primary), 0.3);
    }
    
    .blog-card:hover h2 {
      color: hsl(var(--accent-primary));
    }
  </style>
</Layout>
