---
import Layout from '../layouts/Layout.astro';

export const prerender = false;

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');
---

<Layout title="Competitor Monitor">
  <div class="container page-content">
    <header class="page-header">
      <h1 class="text-gradient">Competitor Monitor</h1>
      <p class="text-secondary text-lg">Watch competitor domains and get alerted when their tech stack changes.</p>
    </header>

    <div class="content-wrapper">
      <form id="addDomainForm" class="glass-panel add-form animate-fade-in">
        <input type="text" id="domainInput" placeholder="example.com" class="domain-input" required />
        <button type="submit" class="btn-primary add-btn" id="addBtn">Watch Domain</button>
      </form>
      <p id="formStatus" class="text-sm mt-2 text-secondary hidden text-center"></p>

      <div id="sseStatus" class="sse-status">
        <span class="sse-dot"></span>
        <span class="sse-text">Connecting...</span>
      </div>

      <div id="watchlist" class="watchlist" style="margin-top:1.5rem;">
        <p class="text-secondary text-center">Loading watchlist...</p>
      </div>

      <div id="activityFeed" class="glass-panel activity-feed hidden" style="margin-top:1.5rem;">
        <h3 class="feed-title">Live Activity Feed</h3>
        <div id="feedItems" class="feed-items"></div>
      </div>
    </div>
  </div>

  <style>
    .page-content { padding-top: 6rem; padding-bottom: 6rem; }
    .page-header { text-align: center; margin-bottom: 2.5rem; }
    .page-header h1 { font-size: 2.25rem; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 0.5rem; }
    .content-wrapper { max-width: 800px; margin: 0 auto; }
    .add-form { padding: 1rem; display: flex; gap: 0.75rem; }
    .domain-input { flex: 1; padding: 0.75rem 1rem; background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-sm); color: hsl(var(--text-primary)); font-family: var(--font-sans); font-size: 0.95rem; outline: none; }
    .domain-input:focus { border-color: hsl(var(--accent-primary)); }
    .add-btn { flex-shrink: 0; padding: 0.75rem 1.5rem; }

    .sse-status { display: flex; align-items: center; gap: 0.5rem; justify-content: center; margin-top: 1rem; font-size: 0.78rem; color: hsl(var(--text-secondary)); }
    .sse-dot { width: 8px; height: 8px; border-radius: 50%; background: #ffa726; animation: pulse-dot 2s ease-in-out infinite; }
    .sse-dot.connected { background: #00e676; }
    .sse-dot.error { background: #ff4b4b; animation: none; }

    @keyframes pulse-dot { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

    .watchlist { display: flex; flex-direction: column; gap: 0.75rem; }
    .watch-card { display: flex; align-items: center; gap: 1rem; padding: 1rem 1.25rem; }
    .watch-domain { font-weight: 700; font-size: 0.95rem; flex: 1; display: flex; align-items: center; gap: 0.5rem; }
    .watch-stats { display: flex; gap: 0.75rem; align-items: center; }
    .watch-stat { text-align: center; font-size: 0.75rem; }
    .watch-stat strong { display: block; font-size: 1rem; }
    .remove-btn { background: none; border: 1px solid rgba(255,75,75,0.3); color: #ff4b4b; padding: 0.3rem 0.6rem; border-radius: var(--radius-sm); font-size: 0.75rem; cursor: pointer; transition: all 0.15s; }
    .remove-btn:hover { background: rgba(255,75,75,0.1); }

    .activity-feed { padding: 1.25rem; }
    .feed-title { font-size: 1rem; font-weight: 700; margin-bottom: 0.75rem; padding-bottom: 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .feed-items { display: flex; flex-direction: column; gap: 0.5rem; max-height: 300px; overflow-y: auto; }
    .feed-item { font-size: 0.8rem; padding: 0.4rem 0; border-bottom: 1px solid rgba(255,255,255,0.04); display: flex; gap: 0.5rem; }
    .feed-time { color: hsl(var(--text-muted)); min-width: 70px; flex-shrink: 0; }

    @media (max-width: 640px) {
      .add-form { flex-direction: column; }
      .watch-card { flex-direction: column; text-align: center; }
      .watch-stats { justify-content: center; }
    }
  </style>

  <script>
    async function loadWatchlist() {
      const container = document.getElementById('watchlist')!;
      try {
        const res = await fetch('/api/monitor');
        if (!res.ok) throw new Error('Failed to load');
        const { watchlist } = await res.json();

        if (watchlist.length === 0) {
          container.innerHTML = '<div class="glass-panel" style="padding:2rem; text-align:center;"><p class="text-secondary">No domains being watched yet. Add one above!</p></div>';
          return;
        }

        container.innerHTML = watchlist.map((w: any) => {
          const gradeColors: Record<string, string> = { 'A': '#00e676', 'B': '#66bb6a', 'C': '#ffa726', 'D': '#ff7043', 'F': '#ff4b4b' };
          return `<div class="glass-panel watch-card">
            <div class="watch-domain">
              <img src="https://logo.clearbit.com/${w.domain}" width="20" height="20" style="border-radius:4px;" onerror="this.style.display='none'" />
              <a href="/report/${w.domain}" style="color:hsl(var(--text-primary)); text-decoration:none;">${w.domain}</a>
            </div>
            <div class="watch-stats">
              <div class="watch-stat"><strong style="color:${gradeColors[w.securityGrade] || 'inherit'}">${w.securityGrade}</strong>Security</div>
              <div class="watch-stat"><strong>${w.perfScore ?? '—'}</strong>Perf</div>
              <div class="watch-stat"><strong>${w.techCount}</strong>Techs</div>
            </div>
            <button class="remove-btn" data-domain="${w.domain}">Remove</button>
          </div>`;
        }).join('');

        container.querySelectorAll('.remove-btn').forEach(btn => {
          btn.addEventListener('click', async () => {
            const domain = (btn as HTMLElement).dataset.domain;
            await fetch('/api/monitor', {
              method: 'POST',
              body: JSON.stringify({ domain, action: 'remove' }),
              headers: { 'Content-Type': 'application/json' }
            });
            loadWatchlist();
          });
        });
      } catch {
        container.innerHTML = '<p class="text-secondary text-center">Failed to load watchlist.</p>';
      }
    }

    const form = document.getElementById('addDomainForm') as HTMLFormElement;
    const formStatus = document.getElementById('formStatus')!;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = document.getElementById('domainInput') as HTMLInputElement;
      const domain = input.value.replace(/^https?:\/\//, '').replace(/\/.*/, '').trim();
      if (!domain) return;

      try {
        const res = await fetch('/api/monitor', {
          method: 'POST',
          body: JSON.stringify({ domain }),
          headers: { 'Content-Type': 'application/json' }
        });
        const data = await res.json();
        formStatus.textContent = data.message || data.error;
        formStatus.style.color = res.ok ? 'hsl(var(--success))' : 'hsl(var(--danger))';
        formStatus.classList.remove('hidden');
        if (res.ok) { input.value = ''; loadWatchlist(); }
      } catch {
        formStatus.textContent = 'Network error';
        formStatus.style.color = 'hsl(var(--danger))';
        formStatus.classList.remove('hidden');
      }
    });

    const sseDot = document.querySelector('.sse-dot')!;
    const sseText = document.querySelector('.sse-text')!;
    const feedContainer = document.getElementById('activityFeed')!;
    const feedItems = document.getElementById('feedItems')!;

    function connectSSE() {
      const es = new EventSource('/api/monitor/events');

      es.addEventListener('connected', () => {
        sseDot.classList.add('connected');
        sseDot.classList.remove('error');
        sseText.textContent = 'Live monitoring active';
      });

      es.addEventListener('update', (e) => {
        const data = JSON.parse(e.data);
        feedContainer.classList.remove('hidden');
        const item = document.createElement('div');
        item.className = 'feed-item';
        item.innerHTML = `<span class="feed-time">${new Date().toLocaleTimeString()}</span>
          <span><strong>${data.domain}</strong> updated — ${data.techCount} techs, Security ${data.securityGrade}, Perf ${data.perfScore ?? '—'}</span>`;
        feedItems.prepend(item);
        loadWatchlist();
      });

      es.addEventListener('heartbeat', () => {
        sseDot.classList.add('connected');
      });

      es.onerror = () => {
        sseDot.classList.remove('connected');
        sseDot.classList.add('error');
        sseText.textContent = 'Reconnecting...';
        es.close();
        setTimeout(connectSSE, 5000);
      };
    }

    loadWatchlist();
    connectSSE();
  </script>
</Layout>
