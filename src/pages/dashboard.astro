---
import Layout from '../layouts/Layout.astro';

import db from '../db/client';

const user = Astro.locals.user;
if (!user) {
	return Astro.redirect("/login");
}

const stmt = db.prepare('SELECT webhook_url FROM user WHERE id = ?');
const userData = stmt.get(user.id) as { webhook_url: string | null } | undefined;
const webhookUrl = userData?.webhook_url || '';
---

<Layout title="Dashboard">
  <div class="container page-content">
    <header class="page-header">
      <h1 class="text-gradient">Welcome Back</h1>
      <p class="text-secondary text-lg">Manage your API keys and run bulk analyses.</p>
      <div class="user-badge">
        <span class="badge font-mono">{user.email}</span>
      </div>
    </header>

    <div class="cards-wrapper">
      <!-- API Access Card -->
      <div class="glass-panel card animate-fade-in card-accent-primary">
        <h2 class="card-title">Developer API Access</h2>
        <p class="text-secondary text-sm mb-6">Use your unique API key to programmatically scan URLs and retrieve JSON intelligence reports.</p>
        
        <label class="field-label">Your Active API Key</label>
        <div class="api-key-row">
          <!-- @ts-ignore -->
          <input type="text" readonly value={user.apiKey} class="mono-input" id="apiKeyInput" />
          <button class="btn-primary copy-btn" id="copyBtn" onclick="navigator.clipboard.writeText(document.getElementById('apiKeyInput').value); this.innerText = 'Copied!'; setTimeout(() => this.innerText = 'Copy', 2000);">Copy</button>
        </div>

        <div class="code-block">
          <p class="text-sm font-semibold mb-2 text-secondary">Example cURL Request:</p>
          <code>curl -X POST https://siteintelica.com/api/analyze \
  -H "Authorization: Bearer <span class="text-accent-primary">YOUR_API_KEY</span>" \
  -H "Content-Type: application/json" \
  -d '&#123;"url":"https://stripe.com"&#125;'</code>
        </div>
      </div>

      <!-- Webhook Integration Card -->
      <div class="glass-panel card animate-fade-in card-accent-secondary" style="animation-delay:0.05s;">
        <h2 class="card-title">Webhook Integration</h2>
        <p class="text-secondary text-sm mb-6">Configure a webhook URL to receive real-time payloads when bulk scans finish or a competitor's stack changes.</p>
        
        <form id="webhookForm" class="api-key-row">
          <!-- @ts-ignore -->
          <input type="url" name="webhookUrl" placeholder="https://your-server.com/api/webhooks/siteintelica" value={webhookUrl} class="mono-input" id="webhookInput" required />
          <button type="submit" class="btn-primary copy-btn" id="saveWebhookBtn">Save</button>
        </form>
        <p id="webhookStatus" class="text-sm text-secondary hidden" style="margin-top:0.75rem;"></p>
      </div>

      <!-- Bulk Scanner -->
      <div class="glass-panel card animate-fade-in card-dashed" style="animation-delay:0.1s;">
        <div class="bulk-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: hsl(var(--accent-primary))">
            <path d="M14 3v4a1 1 0 0 0 1 1h4" /><path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z" /><path d="M9 15h6" /><path d="M12 12v6" />
          </svg>
        </div>
        <h2 class="card-title text-center">Bulk Domain Scanner</h2>
        <p class="text-secondary text-sm text-center mb-6">Upload a CSV/TXT containing up to 50 URLs. Our engine will output a combined JSON intelligence report.</p>
        
        <form id="bulkForm" class="bulk-form">
          <input type="file" id="csvFile" name="file" accept=".csv, .txt" class="file-input" required />
          <button type="submit" class="btn-primary" id="bulkBtn" style="width:100%; padding:0.85rem;">Run Bulk Analysis</button>
        </form>
        <p id="bulkStatus" class="text-sm mt-4 text-secondary hidden text-center"></p>
      </div>
    </div>
  </div>

  <style>
    .page-content {
      padding-top: 6rem;
      padding-bottom: 6rem;
    }

    .page-header {
      text-align: center;
      margin-bottom: 3rem;
    }

    .page-header h1 {
      font-size: 2.5rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      margin-bottom: 0.5rem;
    }

    .user-badge {
      display: flex;
      justify-content: center;
      margin-top: 1rem;
    }

    .cards-wrapper {
      max-width: 800px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .card {
      padding: 2rem;
    }

    .card-accent-primary {
      border-top: 3px solid hsl(var(--accent-primary));
    }

    .card-accent-secondary {
      border-top: 3px solid hsl(var(--accent-secondary));
    }

    .card-dashed {
      border: 1px dashed rgba(255, 255, 255, 0.15);
      text-align: center;
    }

    .card-title {
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .field-label {
      display: block;
      font-size: 0.85rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: hsl(var(--text-secondary));
    }

    .api-key-row {
      display: flex;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
    }

    .mono-input {
      flex-grow: 1;
      padding: 0.75rem 1rem;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      background: rgba(0, 0, 0, 0.25);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: var(--radius-sm);
      color: hsl(var(--text-primary));
      outline: none;
      transition: border-color var(--transition-smooth);
    }

    .mono-input:focus {
      border-color: hsl(var(--accent-primary));
    }

    .copy-btn {
      flex-shrink: 0;
      padding: 0.75rem 1.25rem;
    }

    .code-block {
      background: rgba(0, 0, 0, 0.3);
      border-radius: var(--radius-sm);
      padding: 1rem;
      overflow-x: auto;
    }

    .code-block code {
      font-size: 0.78rem;
      font-family: var(--font-mono);
      color: hsl(var(--text-secondary));
      white-space: pre;
      line-height: 1.6;
    }

    .bulk-icon {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: hsla(var(--accent-primary), 0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1rem;
    }

    .bulk-form {
      width: 100%;
      max-width: 400px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .file-input {
      padding: 0.6rem;
      width: 100%;
      background: rgba(0, 0, 0, 0.25);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: var(--radius-sm);
      color: hsl(var(--text-primary));
      font-family: var(--font-sans);
      font-size: 0.85rem;
    }

    @media (max-width: 640px) {
      .api-key-row { flex-direction: column; }
      .page-header h1 { font-size: 2rem; }
    }
  </style>

  <script>
    const bulkForm = document.getElementById('bulkForm') as HTMLFormElement;
    const bulkBtn = document.getElementById('bulkBtn') as HTMLButtonElement;
    const bulkStatus = document.getElementById('bulkStatus');

    if (bulkForm && bulkBtn && bulkStatus) {
      bulkForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        bulkBtn.disabled = true;
        bulkBtn.innerText = 'Analyzing Queue...';
        bulkStatus.classList.remove('hidden');
        bulkStatus.innerText = 'Processing in the background... Please wait.';
        bulkStatus.style.color = 'hsl(var(--text-secondary))';

        const formData = new FormData(bulkForm);
        try {
          const res = await fetch('/api/bulk-analyze', { method: 'POST', body: formData });
          if (res.ok) {
            const data = await res.json();
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `siteintelica_bulk_report_${Date.now()}.json`;
            a.click();
            window.URL.revokeObjectURL(url);
            bulkStatus.innerText = `Analysis complete! ${data.bulk_processed} domains processed.`;
            bulkStatus.style.color = 'hsl(var(--success))';
          } else {
            const err = await res.json();
            bulkStatus.innerText = 'Error: ' + err.error;
            bulkStatus.style.color = 'hsl(var(--danger))';
          }
        } catch {
          bulkStatus.innerText = 'Network error occurred during bulk pass.';
          bulkStatus.style.color = 'hsl(var(--danger))';
        }
        bulkBtn.disabled = false;
        bulkBtn.innerText = 'Run Bulk Analysis';
      });
    }

    const webhookForm = document.getElementById('webhookForm') as HTMLFormElement;
    const saveWebhookBtn = document.getElementById('saveWebhookBtn') as HTMLButtonElement;
    const webhookStatus = document.getElementById('webhookStatus');

    if (webhookForm && saveWebhookBtn && webhookStatus) {
      webhookForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        saveWebhookBtn.disabled = true;
        saveWebhookBtn.innerText = 'Saving...';
        const formData = new FormData(webhookForm);
        try {
          const res = await fetch('/api/user/webhook', {
            method: 'POST',
            body: JSON.stringify({ webhookUrl: formData.get('webhookUrl') }),
            headers: { 'Content-Type': 'application/json' }
          });
          if (res.ok) {
            webhookStatus.innerText = 'Webhook URL saved successfully!';
            webhookStatus.style.color = 'hsl(var(--success))';
          } else {
            const err = await res.json();
            webhookStatus.innerText = 'Error: ' + err.error;
            webhookStatus.style.color = 'hsl(var(--danger))';
          }
        } catch {
          webhookStatus.innerText = 'Network error occurred.';
          webhookStatus.style.color = 'hsl(var(--danger))';
        }
        webhookStatus.classList.remove('hidden');
        saveWebhookBtn.disabled = false;
        saveWebhookBtn.innerText = 'Save';
      });
    }
  </script>
</Layout>
