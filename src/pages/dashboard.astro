---
import Layout from '../layouts/Layout.astro';
import db, { getApiUsageStats, getMonitoredDomains, getUnreadNotificationCount, getUserScans, getBulkJobs } from '../db/client';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const stmt = db.prepare('SELECT webhook_url, plan, created_at FROM user WHERE id = ?');
const userData = stmt.get(user.id) as { webhook_url: string | null; plan: string; created_at: string } | undefined;
const webhookUrl = userData?.webhook_url || '';
const plan = userData?.plan || 'free';
const memberSince = userData?.created_at ? new Date(userData.created_at).toLocaleDateString() : 'N/A';

const apiUsage = getApiUsageStats(user.id);
const monitored = getMonitoredDomains(user.id);
const unreadNotifs = getUnreadNotificationCount(user.id);
const recentScans = getUserScans(user.id, 5);
const bulkJobs = getBulkJobs(user.id);
---

<Layout title="Dashboard">
  <div class="container page-content">
    <header class="page-header">
      <h1 class="text-gradient">Dashboard</h1>
      <p class="text-secondary text-lg">Your premium intelligence command center.</p>
      <div class="user-meta">
        <span class="badge font-mono">{user.email}</span>
        <span class="plan-badge">{plan.toUpperCase()}</span>
        <span class="text-muted text-sm">Member since {memberSince}</span>
      </div>
    </header>

    <!-- Quick Stats -->
    <div class="stats-grid animate-fade-in">
      <div class="stat-card">
        <div class="stat-icon">📊</div>
        <div class="stat-value">{apiUsage.today}</div>
        <div class="stat-label">Scans Today</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">📡</div>
        <div class="stat-value">{monitored.length}</div>
        <div class="stat-label">Monitored</div>
      </div>
      <a href="/notifications" class="stat-card stat-card-link">
        <div class="stat-icon">🔔</div>
        <div class="stat-value">{unreadNotifs}<span class="stat-small"> unread</span></div>
        <div class="stat-label">Notifications</div>
      </a>
      <div class="stat-card">
        <div class="stat-icon">📈</div>
        <div class="stat-value">{apiUsage.thisMonth}</div>
        <div class="stat-label">This Month</div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="quick-actions animate-fade-in" style="animation-delay: 0.05s;">
      <a href="/monitoring" class="action-btn">📡 Monitor Competitors</a>
      <a href="/uptime" class="action-btn">🟢 Uptime Monitor</a>
      <a href="/leads" class="action-btn">🎯 Search Leads</a>
      <a href="/scraper" class="action-btn">🕷️ Scraper Tools</a>
      <a href="/bulk" class="action-btn">📁 Bulk Analysis</a>
      <a href="/notifications" class="action-btn">🔔 Notifications {unreadNotifs > 0 ? `(${unreadNotifs})` : ''}</a>
      <a href={`/api/export?format=csv&type=scans`} class="action-btn">📥 Export Scans CSV</a>
      <button class="action-btn" id="runChangeDetection">🔄 Check All Monitors Now</button>
    </div>

    <div class="cards-wrapper">
      <!-- API Access Card -->
      <div class="glass-panel card animate-fade-in card-accent-primary" style="animation-delay: 0.08s;">
        <h2 class="card-title">🔑 Developer API Access</h2>
        <p class="text-secondary text-sm mb-6">Use your API key to programmatically scan URLs and retrieve JSON intelligence reports.</p>

        <label class="field-label">Your API Key</label>
        <div class="api-key-row">
          <input type="text" readonly value={user.apiKey} class="mono-input" id="apiKeyInput" />
          <button class="btn-primary copy-btn" id="copyBtn" onclick="navigator.clipboard.writeText(document.getElementById('apiKeyInput').value); this.innerText = 'Copied!'; setTimeout(() => this.innerText = 'Copy', 2000);">Copy</button>
        </div>

        <div class="code-block">
          <p class="text-sm font-semibold mb-2 text-secondary">cURL Example:</p>
          <code>curl -X POST https://siteintelica.com/api/analyze \
  -H "Authorization: Bearer <span class="text-accent-primary">YOUR_KEY</span>" \
  -H "Content-Type: application/json" \
  -d '&#123;"url":"https://stripe.com"&#125;'</code>
        </div>

        <div class="usage-bar-wrap">
          <div class="usage-label">
            <span>API Usage Today</span>
            <span class="text-muted">{apiUsage.today} requests</span>
          </div>
          <div class="usage-bar"><div class="usage-fill" style={`width: ${Math.min(100, (apiUsage.today / 200) * 100)}%`}></div></div>
        </div>
      </div>

      <!-- Webhook Integration Card -->
      <div class="glass-panel card animate-fade-in card-accent-secondary" style="animation-delay: 0.1s;">
        <h2 class="card-title">🔗 Webhook Integration</h2>
        <p class="text-secondary text-sm mb-6">Receive real-time payloads when bulk scans finish or a monitored domain's stack changes.</p>

        <form id="webhookForm" class="api-key-row">
          <input type="url" name="webhookUrl" placeholder="https://your-server.com/webhooks/siteintelica" value={webhookUrl} class="mono-input" id="webhookInput" required />
          <button type="submit" class="btn-primary copy-btn" id="saveWebhookBtn">Save</button>
        </form>
        <p id="webhookStatus" class="text-sm text-secondary hidden" style="margin-top:0.75rem;"></p>
      </div>

      <!-- Recent Scans -->
      <div class="glass-panel card animate-fade-in" style="animation-delay: 0.12s;">
        <h2 class="card-title">🕵️ Recent Scans</h2>
        {recentScans.length > 0 ? (
          <div class="recent-list">
            {recentScans.map((s: any) => (
              <a href={`/report/${s.domain}`} class="recent-item">
                <span class="recent-domain">{s.domain}</span>
                <span class="recent-date">{new Date(s.scanned_at).toLocaleDateString()}</span>
              </a>
            ))}
          </div>
        ) : (
          <p class="text-secondary text-sm">No scans yet. Analyze a website to get started.</p>
        )}
        <a href="/history" class="view-all-link">View all history →</a>
      </div>

      <!-- Monitored Domains Summary -->
      <div class="glass-panel card animate-fade-in" style="animation-delay: 0.14s;">
        <h2 class="card-title">📡 Monitored Domains</h2>
        {monitored.length > 0 ? (
          <div class="recent-list">
            {monitored.slice(0, 5).map((d: any) => (
              <div class="recent-item">
                <span class="recent-domain">{d.domain}</span>
                <span class="recent-date">{d.check_interval}</span>
              </div>
            ))}
          </div>
        ) : (
          <p class="text-secondary text-sm">No domains monitored yet.</p>
        )}
        <a href="/monitoring" class="view-all-link">Manage monitoring →</a>
      </div>

      <!-- Bulk Jobs -->
      {bulkJobs.length > 0 && (
        <div class="glass-panel card animate-fade-in" style="animation-delay: 0.16s;">
          <h2 class="card-title">📁 Recent Bulk Jobs</h2>
          <div class="recent-list">
            {bulkJobs.slice(0, 5).map((j: any) => (
              <div class="recent-item">
                <span class="recent-domain">Job #{j.id} — {j.total_urls} URLs</span>
                <span class={`status-badge status-${j.status}`}>{j.status}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Bulk Scanner Upload -->
      <div class="glass-panel card animate-fade-in card-dashed" style="animation-delay: 0.18s;">
        <div class="bulk-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: hsl(var(--accent-primary))">
            <path d="M14 3v4a1 1 0 0 0 1 1h4" /><path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z" /><path d="M9 15h6" /><path d="M12 12v6" />
          </svg>
        </div>
        <h2 class="card-title text-center">Bulk Domain Scanner</h2>
        <p class="text-secondary text-sm text-center mb-6">Upload CSV/TXT with up to 50 URLs for batch analysis.</p>

        <form id="bulkForm" class="bulk-form">
          <input type="file" id="csvFile" name="file" accept=".csv, .txt" class="file-input" required />
          <button type="submit" class="btn-primary" id="bulkBtn" style="width:100%; padding:0.85rem;">Run Bulk Analysis</button>
        </form>
        <p id="bulkStatus" class="text-sm mt-4 text-secondary hidden text-center"></p>
      </div>
    </div>
  </div>

  <style>
    .page-content { padding-top: 6rem; padding-bottom: 6rem; }
    .page-header { text-align: center; margin-bottom: 2.5rem; }
    .page-header h1 { font-size: 2.5rem; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 0.5rem; }

    .user-meta { display: flex; align-items: center; justify-content: center; gap: 0.75rem; margin-top: 0.75rem; flex-wrap: wrap; }
    .plan-badge {
      padding: 0.2rem 0.6rem; border-radius: 99px; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.04em;
      background: hsla(var(--accent-warm), 0.12); color: hsl(var(--accent-warm));
    }

    /* Stats Grid */
    .stats-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 1rem; max-width: 800px; margin: 0 auto 1.5rem;
    }
    .stat-card {
      background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);
      border-radius: var(--radius-md); padding: 1.25rem; text-align: center; transition: all 0.2s;
    }
    .stat-card:hover { border-color: rgba(255,255,255,0.12); }
    .stat-card-link { text-decoration: none; cursor: pointer; }
    .stat-card-link:hover { border-color: hsl(var(--accent-primary)); }
    .stat-icon { font-size: 1.5rem; margin-bottom: 0.5rem; }
    .stat-value { font-size: 1.8rem; font-weight: 800; letter-spacing: -0.03em; color: hsl(var(--text-primary)); }
    .stat-small { font-size: 0.65rem; font-weight: 500; color: hsl(var(--text-muted)); }
    .stat-label { font-size: 0.75rem; color: hsl(var(--text-muted)); margin-top: 0.25rem; }

    /* Quick Actions */
    .quick-actions {
      display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center;
      max-width: 800px; margin: 0 auto 2rem;
    }
    .action-btn {
      padding: 0.5rem 1rem; border-radius: var(--radius-sm); font-size: 0.8rem; font-weight: 600;
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
      color: hsl(var(--text-secondary)); text-decoration: none; transition: all 0.2s; white-space: nowrap;
    }
    .action-btn:hover { background: hsla(var(--accent-primary), 0.08); border-color: hsla(var(--accent-primary), 0.2); color: hsl(var(--accent-primary)); }

    /* Cards */
    .cards-wrapper { max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; gap: 1.5rem; }
    .card { padding: 1.75rem; }
    .card-accent-primary { border-top: 3px solid hsl(var(--accent-primary)); }
    .card-accent-secondary { border-top: 3px solid hsl(var(--accent-secondary)); }
    .card-dashed { border: 1px dashed rgba(255,255,255,0.15); text-align: center; }
    .card-title { font-size: 1.15rem; font-weight: 700; margin-bottom: 0.5rem; }

    .field-label { display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 0.5rem; color: hsl(var(--text-secondary)); }
    .api-key-row { display: flex; gap: 0.75rem; margin-bottom: 1.25rem; }
    .mono-input {
      flex-grow: 1; padding: 0.75rem 1rem; font-family: var(--font-mono); font-size: 0.85rem;
      background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-sm);
      color: hsl(var(--text-primary)); outline: none; transition: border-color 0.2s;
    }
    .mono-input:focus { border-color: hsl(var(--accent-primary)); }
    .copy-btn { flex-shrink: 0; padding: 0.75rem 1.25rem; }

    .code-block {
      background: rgba(0,0,0,0.3); border-radius: var(--radius-sm); padding: 1rem; overflow-x: auto; margin-bottom: 1.25rem;
    }
    .code-block code { font-size: 0.78rem; font-family: var(--font-mono); color: hsl(var(--text-secondary)); white-space: pre; line-height: 1.6; }

    .usage-bar-wrap { margin-top: 0.5rem; }
    .usage-label { display: flex; justify-content: space-between; font-size: 0.78rem; margin-bottom: 0.4rem; color: hsl(var(--text-secondary)); }
    .usage-bar { height: 6px; background: rgba(255,255,255,0.06); border-radius: 3px; overflow: hidden; }
    .usage-fill { height: 100%; background: hsl(var(--accent-primary)); border-radius: 3px; transition: width 0.3s; }

    /* Recent Lists */
    .recent-list { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: 0.75rem; }
    .recent-item {
      display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 0.65rem;
      border-radius: var(--radius-sm); transition: background 0.2s; text-decoration: none;
    }
    .recent-item:hover { background: rgba(255,255,255,0.04); }
    .recent-domain { font-size: 0.85rem; font-weight: 600; color: hsl(var(--text-primary)); }
    .recent-date { font-size: 0.72rem; color: hsl(var(--text-muted)); }
    .view-all-link { font-size: 0.8rem; color: hsl(var(--accent-primary)); text-decoration: none; font-weight: 600; }
    .view-all-link:hover { text-decoration: underline; }

    .status-badge { padding: 0.15rem 0.5rem; border-radius: 99px; font-size: 0.68rem; font-weight: 700; }
    .status-complete { background: hsla(var(--success), 0.12); color: hsl(var(--success)); }
    .status-processing { background: hsla(var(--warning), 0.12); color: hsl(var(--warning)); }
    .status-pending { background: rgba(255,255,255,0.08); color: hsl(var(--text-muted)); }

    .bulk-icon { width: 48px; height: 48px; border-radius: 50%; background: hsla(var(--accent-primary), 0.15); display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; }
    .bulk-form { width: 100%; max-width: 400px; margin: 0 auto; display: flex; flex-direction: column; gap: 0.75rem; }
    .file-input { padding: 0.6rem; width: 100%; background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-sm); color: hsl(var(--text-primary)); font-family: var(--font-sans); font-size: 0.85rem; }

    @media (max-width: 640px) {
      .api-key-row { flex-direction: column; }
      .page-header h1 { font-size: 2rem; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>

  <script>
    const bulkForm = document.getElementById('bulkForm') as HTMLFormElement;
    const bulkBtn = document.getElementById('bulkBtn') as HTMLButtonElement;
    const bulkStatus = document.getElementById('bulkStatus');

    if (bulkForm && bulkBtn && bulkStatus) {
      bulkForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        bulkBtn.disabled = true;
        bulkBtn.innerText = 'Analyzing...';
        bulkStatus.classList.remove('hidden');
        bulkStatus.innerText = 'Processing domains... This may take a minute.';
        bulkStatus.style.color = 'hsl(var(--text-secondary))';

        const formData = new FormData(bulkForm);
        try {
          const res = await fetch('/api/bulk-analyze', { method: 'POST', body: formData });
          if (res.ok) {
            const data = await res.json();
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `siteintelica_bulk_${Date.now()}.json`;
            a.click();
            window.URL.revokeObjectURL(url);
            bulkStatus.innerText = `Complete! ${data.successCount}/${data.totalProcessed} domains scanned successfully.`;
            bulkStatus.style.color = 'hsl(var(--success))';
          } else {
            const err = await res.json();
            bulkStatus.innerText = 'Error: ' + err.error;
            bulkStatus.style.color = 'hsl(var(--danger))';
          }
        } catch {
          bulkStatus.innerText = 'Network error occurred.';
          bulkStatus.style.color = 'hsl(var(--danger))';
        }
        bulkBtn.disabled = false;
        bulkBtn.innerText = 'Run Bulk Analysis';
      });
    }

    const webhookForm = document.getElementById('webhookForm') as HTMLFormElement;
    const saveWebhookBtn = document.getElementById('saveWebhookBtn') as HTMLButtonElement;
    const webhookStatus = document.getElementById('webhookStatus');

    if (webhookForm && saveWebhookBtn && webhookStatus) {
      webhookForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        saveWebhookBtn.disabled = true;
        saveWebhookBtn.innerText = 'Saving...';
        const formData = new FormData(webhookForm);
        try {
          const res = await fetch('/api/user/webhook', {
            method: 'POST',
            body: JSON.stringify({ webhookUrl: formData.get('webhookUrl') }),
            headers: { 'Content-Type': 'application/json' }
          });
          if (res.ok) {
            webhookStatus.innerText = 'Webhook URL saved!';
            webhookStatus.style.color = 'hsl(var(--success))';
          } else {
            const err = await res.json();
            webhookStatus.innerText = 'Error: ' + err.error;
            webhookStatus.style.color = 'hsl(var(--danger))';
          }
        } catch {
          webhookStatus.innerText = 'Network error occurred.';
          webhookStatus.style.color = 'hsl(var(--danger))';
        }
        webhookStatus.classList.remove('hidden');
        saveWebhookBtn.disabled = false;
        saveWebhookBtn.innerText = 'Save';
      });
    }

    const runDetectionBtn = document.getElementById('runChangeDetection');
    if (runDetectionBtn) {
      runDetectionBtn.addEventListener('click', async () => {
        runDetectionBtn.textContent = '⏳ Checking...';
        (runDetectionBtn as HTMLButtonElement).disabled = true;
        try {
          const res = await fetch('/api/check-domains', { method: 'POST' });
          const data = await res.json();
          runDetectionBtn.textContent = res.ok ? `✅ ${data.message}` : `Error: ${data.error}`;
        } catch {
          runDetectionBtn.textContent = '❌ Failed';
        }
        setTimeout(() => {
          runDetectionBtn.textContent = '🔄 Check All Monitors Now';
          (runDetectionBtn as HTMLButtonElement).disabled = false;
        }, 5000);
      });
    }
  </script>
</Layout>
