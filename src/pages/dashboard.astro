---
import Layout from '../layouts/Layout.astro';

const user = Astro.locals.user;
if (!user) {
	return Astro.redirect("/login");
}
---

<Layout title="Dashboard | SiteIntelica">
  <div class="container pt-32 pb-24">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 class="text-4xl font-extrabold mb-2">Welcome Back</h1>
            <p class="text-secondary text-lg">Manage your SiteIntelica API keys and run bulk analyses.</p>
        </div>
        <div style="background: rgba(255, 255, 255, 0.05); padding: 0.5rem 1rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); font-family: monospace; font-size: 0.9rem;">
            {user.email}
        </div>
    </div>

    <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 1.5rem;">
        
        <!-- API Access Card -->
        <div class="glass-panel p-6 animate-fade-in" style="border-top: 3px solid hsl(var(--accent-primary));">
            <h2 class="text-2xl font-bold mb-4">Developer API Access</h2>
            <p class="text-secondary mb-6 text-sm">Use your unique API key to programmatically scan URLs and retrieve JSON intelligence reports bypassing the frontend UI.</p>
            
            <label class="text-sm font-semibold mb-2 block">Your Active API Key</label>
            <div style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem;">
                <!-- @ts-ignore -->
                <input type="text" readonly value={user.apiKey} class="search-input" id="apiKeyInput" style="flex-grow: 1; padding: 0.75rem; font-family: monospace; background: rgba(0,0,0,0.2) !important; color: #fff;" />
                <button class="btn-primary" id="copyBtn" onclick="navigator.clipboard.writeText(document.getElementById('apiKeyInput').value); this.innerText = 'Copied!'; setTimeout(() => this.innerText = 'Copy', 2000);">Copy</button>
            </div>

            <div style="background: rgba(0, 0, 0, 0.3); border-radius: 8px; padding: 1rem; overflow-x: auto;">
                <p class="text-sm font-semibold mb-2 text-secondary">Example cURL Request:</p>
                <code style="font-size: 0.8rem; font-family: monospace; color: #a9b1d6; white-space: pre;">curl -X POST https://siteintelica.com/api/analyze \
  -H "Authorization: Bearer <span style="color:hsl(var(--accent-primary))">YOUR_API_KEY</span>" \
  -H "Content-Type: application/json" \
  -d '&#123;"url":"https://stripe.com"&#125;'</code>
            </div>
        </div>

        <!-- Bulk Scanner Block -->
        <div class="glass-panel p-6 animate-fade-in" style="animation-delay: 0.1s; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; border: 1px dashed rgba(255,255,255,0.2);">
            <div style="width: 48px; height: 48px; border-radius: 50%; background: hsla(var(--accent-primary), 0.2); display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: hsl(var(--accent-primary))">
                    <path d="M14 3v4a1 1 0 0 0 1 1h4"></path>
                    <path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z"></path>
                    <path d="M9 15h6"></path>
                    <path d="M12 12v6"></path>
                </svg>
            </div>
            <h2 class="text-xl font-bold mb-2">Bulk Domain Scanner</h2>
            <p class="text-secondary mb-6 text-sm">Upload a CSV/TXT containing up to 50 URLs. Our engine will iterate through the list and output a combined JSON intelligence report.</p>
            
            <form id="bulkForm" style="width: 100%; display: flex; flex-direction: column; gap: 1rem;">
                <input type="file" id="csvFile" name="file" accept=".csv, .txt" class="search-input" style="padding: 0.5rem; width: 100%; background: rgba(0,0,0,0.2) !important;" required />
                <button type="submit" class="btn-primary" id="bulkBtn" style="justify-content: center; align-self: center; width: auto;">Run Bulk Analysis</button>
            </form>
            <p id="bulkStatus" class="text-sm mt-4 text-secondary hidden">Processing in the background... Please wait.</p>
        </div>

    </div>
  </div>

  <script>
      const bulkForm = document.getElementById('bulkForm') as HTMLFormElement;
      const bulkBtn = document.getElementById('bulkBtn') as HTMLButtonElement;
      const bulkStatus = document.getElementById('bulkStatus');

      if (bulkForm && bulkBtn && bulkStatus) {
          bulkForm.addEventListener('submit', async (e) => {
              e.preventDefault();
              bulkBtn.disabled = true;
              bulkBtn.innerText = 'Analyzing Queue...';
              bulkStatus.classList.remove('hidden');
              bulkStatus.innerText = 'Processing in the background... Please wait.';
              bulkStatus.style.color = 'var(--text-secondary)';

              const formData = new FormData(bulkForm);
              try {
                  const res = await fetch('/api/bulk-analyze', {
                      method: 'POST',
                      body: formData
                  });
                  
                  if (res.ok) {
                      const data = await res.json();
                      const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
                      const url = window.URL.createObjectURL(blob);
                      const a = document.createElement('a');
                      a.href = url;
                      a.download = `siteintelica_bulk_report_${Date.now()}.json`;
                      a.click();
                      window.URL.revokeObjectURL(url);
                      bulkStatus.innerText = `Analysis complete! Sent ${data.bulk_processed} domain reports.`;
                      bulkStatus.style.color = '#00e676';
                  } else {
                      const err = await res.json();
                      bulkStatus.innerText = 'Error: ' + err.error;
                      bulkStatus.style.color = '#ff4b4b';
                  }
              } catch(e) {
                  bulkStatus.innerText = 'Network error occurred during bulk pass.';
                  bulkStatus.style.color = '#ff4b4b';
              }
              
              bulkBtn.disabled = false;
              bulkBtn.innerText = 'Run Bulk Analysis';
          });
      }
  </script>
</Layout>
